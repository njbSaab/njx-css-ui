    <script is:inline>
        // ── Theme switching ──
        function syncThemeCards(theme) {
            document
                .querySelectorAll('.theme-card[data-theme]')
                .forEach((card) =>
                    card.classList.toggle(
                        'active',
                        card.dataset.theme === theme,
                    ),
                );
        }

        const initialTheme =
            document.documentElement.getAttribute('data-theme') || 'dark';
        syncThemeCards(initialTheme);

        document.querySelectorAll('.theme-card[data-theme]').forEach((card) =>
            card.addEventListener('click', () => {
                const theme = card.dataset.theme;
                document.documentElement.setAttribute('data-theme', theme);
                localStorage.setItem('njx-theme', theme);
                syncThemeCards(theme);
                document
                    .querySelectorAll('.lib-theme-pill')
                    .forEach((p) =>
                        p.classList.toggle(
                            'active',
                            p.title && p.title.toLowerCase() === theme,
                        ),
                    );
            }),
        );

        // ── Search ──
        (function () {
            const input = document.getElementById('libSearchInput');
            const dropdown = document.getElementById('libSearchDropdown');
            if (!input || !dropdown) return;

            const ICONS = {
                themes: '🎨',
                variants: '⚡',
                headings: '𝐓',
                inline: '🔗',
                lists: '≡',
                'code-block': '⌨',
                tables: '📊',
                inputs: '📋',
                controls: '🎛',
                buttons: '🔲',
                article: '📄',
                semantic: '🏗',
                dl: '🖼',
                details: '🔽',
                progress: '▮',
                dialog: '💬',
                loading: '⏳',
            };

            const index = [];
            document.querySelectorAll('.cl-section[id]').forEach((section) => {
                const id = section.id;
                const titleEl = section.querySelector('.lib-section-title');
                const title = titleEl ? titleEl.textContent.trim() : id;
                const icon = ICONS[id] || '◻';
                index.push({
                    label: title,
                    section: 'Section',
                    icon,
                    el: section,
                });
                section
                    .querySelectorAll('.lib-component-label')
                    .forEach((lbl) => {
                        const t = lbl.textContent.trim();
                        if (t)
                            index.push({
                                label: t,
                                section: title,
                                icon: '◈',
                                el: lbl.closest('.lib-component') || section,
                            });
                    });
            });

            let focusedIdx = -1,
                currentItems = [];

            function hl(text, q) {
                if (!q) return text;
                return text.replace(
                    new RegExp(
                        `(${q.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')})`,
                        'gi',
                    ),
                    '<mark>$1</mark>',
                );
            }

            function render(query) {
                const q = query.trim().toLowerCase();
                dropdown.innerHTML = '';
                focusedIdx = -1;
                if (!q) {
                    dropdown.classList.remove('open');
                    return;
                }

                const results = index.filter(
                    (i) =>
                        i.label.toLowerCase().includes(q) ||
                        i.section.toLowerCase().includes(q),
                );

                if (!results.length) {
                    dropdown.innerHTML = `<div class="lib-search-empty">No results for "<strong>${query}</strong>"</div>`;
                    dropdown.classList.add('open');
                    currentItems = [];
                    return;
                }

                const groups = {};
                results.forEach((i) => {
                    const g = i.section;
                    if (!groups[g]) groups[g] = [];
                    groups[g].push(i);
                });

                currentItems = [];
                Object.entries(groups).forEach(([grp, items]) => {
                    const lbl = document.createElement('div');
                    lbl.className = 'lib-search-group-label';
                    lbl.textContent = grp;
                    dropdown.appendChild(lbl);
                    items.forEach((item) => {
                        const row = document.createElement('div');
                        row.className = 'lib-search-item';
                        row.innerHTML = `<div class="lib-search-item-icon">${item.icon}</div><div class="lib-search-item-body"><div class="lib-search-item-name">${hl(item.label, q)}</div><div class="lib-search-item-section">${item.section}</div></div>`;
                        row.addEventListener('click', () => select(item));
                        dropdown.appendChild(row);
                        currentItems.push({ el: row, item });
                    });
                });
                dropdown.classList.add('open');
            }

            function select(item) {
                item.el.scrollIntoView({ behavior: 'smooth', block: 'start' });
                input.value = '';
                dropdown.classList.remove('open');
                input.blur();
            }

            function moveFocus(dir) {
                if (!currentItems.length) return;
                currentItems[focusedIdx]?.el.classList.remove('focused');
                focusedIdx =
                    (focusedIdx + dir + currentItems.length) %
                    currentItems.length;
                currentItems[focusedIdx].el.classList.add('focused');
                currentItems[focusedIdx].el.scrollIntoView({
                    block: 'nearest',
                });
            }

            input.addEventListener('input', () => render(input.value));
            input.addEventListener('keydown', (e) => {
                if (e.key === 'ArrowDown') {
                    e.preventDefault();
                    moveFocus(1);
                } else if (e.key === 'ArrowUp') {
                    e.preventDefault();
                    moveFocus(-1);
                } else if (e.key === 'Enter' && focusedIdx >= 0)
                    select(currentItems[focusedIdx].item);
                else if (e.key === 'Escape') {
                    dropdown.classList.remove('open');
                    input.blur();
                }
            });
            document.addEventListener('click', (e) => {
                if (!e.target.closest('#libSearch'))
                    dropdown.classList.remove('open');
            });
            document.addEventListener('keydown', (e) => {
                if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
                    e.preventDefault();
                    input.focus();
                    input.select();
                }
            });
        })();

        // ── Sidebar active section ──
        const sidebarLinks = document.querySelectorAll(
            '.lib-sidebar a[href^="#"]',
        );
        const sectionObserver = new IntersectionObserver(
            (entries) => {
                entries.forEach((e) => {
                    if (e.isIntersecting) {
                        sidebarLinks.forEach((a) =>
                            a.classList.toggle(
                                'active',
                                a.getAttribute('href') === '#' + e.target.id,
                            ),
                        );
                    }
                });
            },
            { rootMargin: '-15% 0px -70% 0px' },
        );
        document
            .querySelectorAll('.cl-section[id]')
            .forEach((s) => sectionObserver.observe(s));

        // Trigger lib-docs.js initialization
        document.dispatchEvent(new Event('components-loaded'));
    </script>
    <Bottombar activePage="classless" />
