          tsw.querySelectorAll('.s').forEach(function (el) {
            el.classList.toggle('on', el.dataset.t === t);
          });
        };
        tsw.appendChild(s);
      });

      var attrEl = document.getElementById('ov-attr');
      if (attrEl) attrEl.textContent = 'data-theme="' + curTheme + '"';

      var PG_MODES = {
        auth: '<div class="pg-card full"><div class="t">Sign in</div><div class="x">Welcome back. Two-factor enabled.</div><div style="display:flex;flex-direction:column;gap:8px;margin-top:8px"><input class="inp inp-sm" placeholder="email@team.dev" style="font-size:12px"><input class="inp inp-sm" placeholder="••••••••" type="password" style="font-size:12px"><button class="btn btn-primary btn-sm" style="width:100%;justify-content:center;margin-top:4px">Continue</button></div></div><div class="pg-card"><div class="t">SSO</div><button class="btn btn-ghost btn-sm" style="width:100%;justify-content:center;margin-top:6px">Google</button><button class="btn btn-ghost btn-sm" style="width:100%;justify-content:center;margin-top:6px">GitHub</button></div><div class="pg-card"><div class="t">Status</div><div class="pg-tags"><span class="tag tag-primary">primary</span><span class="tag tag-success">live</span><span class="badge badge-error">3</span></div></div>',
        dash: '<div class="pg-card full"><div class="t">Revenue · 7d</div><div class="x">+12.4% vs last week</div><div class="pg-progress"><div style="width:72%"></div></div><div class="pg-progress" style="margin-top:6px"><div style="width:48%"></div></div><div class="pg-progress" style="margin-top:6px"><div style="width:88%"></div></div></div><div class="pg-card"><div class="t">Users</div><div style="font-family:Poppins,sans-serif;font-size:24px;font-weight:900;color:var(--color-light);margin-top:4px">12,401</div><span class="tag tag-success" style="font-size:10px;margin-top:4px;display:inline-block">+4.2%</span></div><div class="pg-card"><div class="t">Errors</div><div style="font-family:Poppins,sans-serif;font-size:24px;font-weight:900;color:var(--color-light);margin-top:4px">0</div><span class="tag tag-primary" style="font-size:10px;margin-top:4px;display:inline-block">healthy</span></div>',
        form: '<div class="pg-card full"><div class="t">New project</div><div class="x">Set the basics, you can change anything later.</div><div style="display:flex;flex-direction:column;gap:8px;margin-top:8px"><input class="inp inp-sm" placeholder="Project name" style="font-size:12px"><input class="inp inp-sm" placeholder="Slug · auto" style="font-size:12px"><div style="display:flex;gap:6px;margin-top:4px;flex-wrap:wrap"><span class="tag tag-primary">web</span><span class="tag tag-filled-primary">api</span></div><div style="display:flex;gap:6px;margin-top:6px"><button class="btn btn-ghost btn-sm" style="flex:1;justify-content:center">Cancel</button><button class="btn btn-primary btn-sm" style="flex:1;justify-content:center">Create</button></div></div></div>',
      };
      function setMode(m) {
        var body = document.getElementById('ov-pgbody');
        if (body) body.innerHTML = PG_MODES[m] || '';
        document.querySelectorAll('#ov-modeseg button').forEach(function (b) {
          b.classList.toggle('on', b.dataset.m === m);
        });
      }
      document.querySelectorAll('#ov-modeseg button').forEach(function (b) {
        b.onclick = function () {
          setMode(b.dataset.m);
        };
      });
      setMode('auth');
    })();
  });
</script>
