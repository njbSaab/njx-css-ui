---
import BaseLayout from '../layouts/BaseLayout.astro';
import PagesTopbar from '../components/PagesTopbar.astro';
import PagesFooter from '../components/PagesFooter.astro';
import Bottombar from '../components/Bottombar.astro';
import Demo from '../components/demo/Demo.astro';
import { LIB_VERSION, SIZE_FULL } from '../lib/meta';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="njX UI — 308 KB CSS library. 9 themes. Zero dependencies."
  description="A modern CSS component library — 308 KB, zero dependencies, zero build step. Switch the entire UI theme with a single HTML attribute."
>
  <!-- ══ NAV ══ -->
  <PagesTopbar activePage="overview" />

  <!-- ══════════════════════ HERO ══════════════════════ -->
  <section class="hero">
    <div class="wrap">
      <div class="hero-grid">
        <!-- Left: copy + CTAs + stats -->
        <div class="hero-left">
          <div class="label">
            <span class="pulse"></span>
            Open Source · MIT License · v{LIB_VERSION}
          </div>
          <h1>
            <span class="grad">Pure CSS.</span><br />
            Nine&nbsp;themes.<br />
            <span class="dim">Zero&nbsp;build.</span>
          </h1>
          <p class="sub">
            A 40&nbsp;KB CSS library that flips themes with one HTML attribute.
            Every demo on this page is live — change the theme and watch every
            component re-tint instantly.
          </p>
          <div class="hero-cta">
            <a href={`${base}quickstart`} class="btn-pill primary"
              >↓ Get Started</a
            >
            <a href={`${base}`} class="btn-pill ghost">Try it live</a>
          </div>
          <div class="stats-inline">
            <div>
              <div class="v">{SIZE_FULL}</div><div class="l">Bundle</div>
            </div>
            <div><div class="v">9</div><div class="l">Themes</div></div>
            <div><div class="v">30+</div><div class="l">Components</div></div>
            <div><div class="v">0</div><div class="l">Deps</div></div>
          </div>
        </div>

        <!-- Right: Interactive Playground -->
        <div class="playground">
          <div class="pg-bar">
            <span class="dot" style="background:#ff5f57"></span>
            <span class="dot" style="background:#febc2e"></span>
            <span class="dot" style="background:#28c840"></span>
            <div class="url">
              &lt;html <span style="color:var(--color-primary)" id="ov-attr"
                >data-theme="dark"</span
              >&gt;
            </div>
          </div>
          <div class="pg-controls">
            <div class="seg" id="ov-modeseg">
              <button class="on" data-m="auth">Auth</button>
              <button data-m="dash">Dashboard</button>
              <button data-m="form">Form</button>
            </div>
            <div class="pg-tswatches" id="ov-tswatches"></div>
          </div>
          <div class="pg-body" id="ov-pgbody"></div>
        </div>
      </div>
    </div>
  </section>

  <div class="container">
    <Demo />
  </div>

  <!-- ══════════════════════ THEME SYSTEM ══════════════════════ -->
  <div class="sc-section sc-section-center" style="padding-top:100px">
    <span class="sc-eyebrow">Theme system</span>
    <h2 class="sc-heading">
      Switch the entire UI<br />with one HTML attribute
    </h2>
    <p class="sc-subheading center">
      No CSS overrides. No JavaScript required. Every component adapts
      automatically through CSS custom properties inherited from <code
        style="color:var(--color-primary);font-family:'Roboto Mono',monospace"
        >data-theme</code
      >.
    </p>
    <div class="sc-theme-pills">
      <div class="sc-tpill active" style="--pill-color:#14a0ff" data-t="dark">
        <span class="dot"></span>Dark
      </div>
      <div class="sc-tpill" style="--pill-color:#94a3b8" data-t="light">
        <span class="dot"></span>Light
      </div>
      <div class="sc-tpill" style="--pill-color:#f43f5e" data-t="red">
        <span class="dot"></span>Red
      </div>
      <div class="sc-tpill" style="--pill-color:#3b82f6" data-t="blue">
        <span class="dot"></span>Blue
      </div>
      <div class="sc-tpill" style="--pill-color:#22c55e" data-t="green">
        <span class="dot"></span>Green
      </div>
      <div class="sc-tpill" style="--pill-color:#00e5ff" data-t="cyan">
        <span class="dot"></span>Cyan
      </div>
      <div class="sc-tpill" style="--pill-color:#facc15" data-t="yellow">
        <span class="dot"></span>Yellow
      </div>
      <div class="sc-tpill" style="--pill-color:#ec4899" data-t="pink">
        <span class="dot"></span>Pink
      </div>
      <div class="sc-tpill" style="--pill-color:#a855f7" data-t="purple">
        <span class="dot"></span>Purple
      </div>
    </div>
    <div class="sc-theme-preview">
      <div class="sc-theme-preview-bar">
        <div class="sc-tpbar-dot" style="background:#ff5f57"></div>
        <div class="sc-tpbar-dot" style="background:#febc2e"></div>
        <div class="sc-tpbar-dot" style="background:#28c840"></div>
        <div class="sc-tpbar-url">
          &lt;html <span style="color:var(--color-primary)" id="ov-attr2"
            >data-theme="dark"</span
          >&gt;
        </div>
      </div>
      <div class="sc-theme-preview-body">
        <div class="sc-demo-card">
          <div class="sc-demo-card-title" style="color:var(--color-primary)">
            Dashboard
          </div>
          <div class="sc-demo-card-text">
            Real-time analytics overview with live metrics and trend data.
          </div>
          <button class="btn btn-primary btn-sm">View Stats</button>
        </div>
        <div class="sc-demo-card">
          <div class="sc-demo-card-title">Sign in</div>
          <div
            style="display:flex;flex-direction:column;gap:10px;margin-top:10px"
          >
            <input
              class="inp inp-sm"
              placeholder="Email"
              type="email"
              style="font-size:12px"
            />
            <input
              class="inp inp-sm"
              placeholder="Password"
              type="password"
              style="font-size:12px"
            />
            <button class="btn btn-primary btn-sm" style="width:100%"
              >Login</button
            >
          </div>
        </div>
        <div class="sc-demo-card">
          <div class="sc-demo-card-title">Components</div>
          <div class="sc-demo-card-text">Mix and match freely.</div>
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-top:10px">
            <span class="tag tag-primary" style="font-size:11px">primary</span>
            <span class="tag tag-success" style="font-size:11px">success</span>
            <span class="tag tag-filled-primary" style="font-size:11px"
              >filled</span
            >
            <span class="badge badge-error" style="font-size:11px">3</span>
          </div>
          <div style="margin-top:10px">
            <div
              style="height:6px;background:color-mix(in srgb,var(--color-primary) 20%,transparent);border-radius:4px"
            >
              <div
                style="height:100%;width:65%;background:var(--color-primary);border-radius:4px;transition:width 0.6s"
              >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div
      style="margin-top:24px;font-family:'Roboto Mono',monospace;font-size:13px;color:var(--color-muted)"
    >
      That's literally it →
      <span
        style="color:var(--color-primary);background:color-mix(in srgb,var(--color-primary) 10%,transparent);padding:3px 10px;border-radius:6px"
        >&lt;html data-theme="purple"&gt;</span
      >
    </div>
  </div>

  <!-- ══════════════════════ FEATURES ══════════════════════ -->
  <div class="sc-section" style="padding-top:40px; padding-bottom: 0;">
    <div style="margin-bottom:40px">
      <span class="sc-eyebrow">Why njX</span>
      <h2 class="sc-heading">Everything you need.<br />Nothing you don't.</h2>
      <p class="sc-subheading">
        Built on CSS custom properties from the ground up. No preprocessors, no
        PostCSS, no config files.
      </p>
    </div>
    <div class="sc-features">
      <div class="sc-feat">
        <span class="sc-feat-icon">🎨</span><div class="sc-feat-title">
          9 Themes, one attribute
        </div><div class="sc-feat-desc">
          Dark, Light, Red, Blue, Green, Cyan, Yellow, Pink, Purple. Every
          component adapts automatically. No extra CSS needed.
        </div><span class="sc-feat-tag">data-theme="purple"</span>
      </div>
      <div class="sc-feat">
        <span class="sc-feat-icon">⚡</span><div class="sc-feat-title">
          Zero build step
        </div><div class="sc-feat-desc">
          One CDN link and you're running. No npm, no webpack, no PostCSS
          config. Works in any HTML file, today.
        </div><span class="sc-feat-tag">CDN ready</span>
      </div>
      <div class="sc-feat">
        <span class="sc-feat-icon">🔑</span><div class="sc-feat-title">
          CSS Variables First
        </div><div class="sc-feat-desc">
          60+ design tokens. Change <code style="color:var(--color-primary)"
            >--color-primary</code
          > once and it ripples through every component.
        </div><span class="sc-feat-tag">60+ tokens</span>
      </div>
      <div class="sc-feat">
        <span class="sc-feat-icon">✨</span><div class="sc-feat-title">
          Hover effects built in
        </div><div class="sc-feat-desc">
          30+ hover classes: scale, lift, glow, rotate, shimmer, blur,
          brightness. Effects that usually need custom CSS — already here.
        </div><span class="sc-feat-tag">30+ effects</span>
      </div>
      <div class="sc-feat">
        <span class="sc-feat-icon">🌈</span><div class="sc-feat-title">
          Gradients out of the box
        </div><div class="sc-feat-desc">
          15+ background gradients, 8 text gradients, gradient borders, animated
          gradients. Design-ready without a single line of custom CSS.
        </div><span class="sc-feat-tag">_gradients.css</span>
      </div>
      <div class="sc-feat">
        <span class="sc-feat-icon">🎭</span><div class="sc-feat-title">
          Animations included
        </div><div class="sc-feat-desc">
          Float, pulse, bounce, spin, heartbeat, wiggle, glow, neon text,
          rainbow, fade-in variants. Add a class, get an animation.
        </div><span class="sc-feat-tag">_animations.css</span>
      </div>
      <div class="sc-feat">
        <span class="sc-feat-icon">♻️</span><div class="sc-feat-title">
          Bulma compatible
        </div><div class="sc-feat-desc">
          Already using Bulma? Classes like <code
            style="color:var(--color-primary)">.button.is-primary</code
          > work without changes. Migrate progressively, zero rewrites.
        </div><span class="sc-feat-tag">Drop-in replacement</span>
      </div>
      <div class="sc-feat">
        <span class="sc-feat-icon">📐</span><div class="sc-feat-title">
          Two grid systems
        </div><div class="sc-feat-desc">
          Classic 12-col flex grid (<code style="color:var(--color-primary)"
            >.row</code
          > + <code style="color:var(--color-primary)">.col-*</code>) and modern
          CSS Grid helpers. Pick what fits.
        </div><span class="sc-feat-tag">_grid.css</span>
      </div>
      <div class="sc-feat">
        <span class="sc-feat-icon">🎯</span><div class="sc-feat-title">
          Tailwind-compatible utils
        </div><div class="sc-feat-desc">
          Same class names as Tailwind — <code
            style="color:var(--color-primary)"
            >flex gap-4 mt-6 px-4 rounded-lg</code
          > work out of the box. Zero PostCSS, zero build step, 40&nbsp;KB instead
          of 3&nbsp;MB.
        </div><span class="sc-feat-tag">_utils.css</span>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ COMPARISON ══════════════════════ -->
  <div class="sc-section" style="padding-top:40px padding-bottom: 0;">
    <div style="margin-bottom:40px">
      <span class="sc-eyebrow">Comparison</span>
      <h2 class="sc-heading">
        Heavier than chota.<br />Lighter than everything else.
      </h2>
      <p class="sc-subheading">
        308 KB gets you themes, animations, hover effects and gradients —
        features that don't exist anywhere else at this weight.
      </p>
    </div>
    <div class="sc-table-wrap">
      <table class="sc-table">
        <thead>
          <tr>
            <th style="text-align:left">Feature</th>
            <th>chota</th>
            <th>Pico CSS</th>
            <th>Bulma</th>
            <th style="color:var(--color-primary)">njX ✦</th>
          </tr>
        </thead>
        <tbody>
          <tr
            ><td>Bundle size</td><td>3 KB</td><td>9 KB</td><td>78 KB</td><td
              style="color:var(--color-primary);font-weight:700">~308 KB</td
            ></tr
          >
          <tr
            ><td>Built-in themes</td><td><span class="sc-cross">—</span></td><td
              >2</td
            ><td><span class="sc-cross">—</span></td><td
              style="color:var(--color-primary);font-weight:700">9</td
            ></tr
          >
          <tr
            ><td>CSS Custom Properties</td><td>partial</td><td
              ><span class="sc-check">✓</span></td
            ><td><span class="sc-cross">—</span></td><td
              style="color:var(--color-primary);font-weight:700">✓ full</td
            ></tr
          >
          <tr
            ><td>Hover effects</td><td><span class="sc-cross">—</span></td><td
              ><span class="sc-cross">—</span></td
            ><td><span class="sc-cross">—</span></td><td
              style="color:var(--color-primary);font-weight:700">30+</td
            ></tr
          >
          <tr
            ><td>Gradients</td><td><span class="sc-cross">—</span></td><td
              ><span class="sc-cross">—</span></td
            ><td><span class="sc-cross">—</span></td><td
              style="color:var(--color-primary);font-weight:700">15+</td
            ></tr
          >
          <tr
            ><td>Animations</td><td><span class="sc-cross">—</span></td><td
              ><span class="sc-cross">—</span></td
            ><td><span class="sc-cross">—</span></td><td
              style="color:var(--color-primary);font-weight:700">✓</td
            ></tr
          >
          <tr
            ><td>Text gradients</td><td><span class="sc-cross">—</span></td><td
              ><span class="sc-cross">—</span></td
            ><td><span class="sc-cross">—</span></td><td
              style="color:var(--color-primary);font-weight:700">8 styles</td
            ></tr
          >
          <tr
            ><td>Bulma compatible</td><td><span class="sc-cross">—</span></td
            ><td><span class="sc-cross">—</span></td><td>—</td><td
              style="color:var(--color-primary);font-weight:700">✓</td
            ></tr
          >
          <tr
            ><td>Build step required</td><td>No</td><td>No</td><td>No</td><td
              style="color:var(--color-success);font-weight:700">No</td
            ></tr
          >
          <tr
            ><td>Tailwind-compatible utils</td><td
              ><span class="sc-cross">—</span></td
            ><td><span class="sc-cross">—</span></td><td
              ><span class="sc-cross">—</span></td
            ><td style="color:var(--color-primary);font-weight:700"
              >✓ same API</td
            ></tr
          >
          <tr style="border-bottom:none"
            ><td>JS required</td><td>No</td><td>No</td><td>No</td><td
              style="color:var(--color-success);font-weight:700">No</td
            ></tr
          >
        </tbody>
      </table>
    </div>
  </div>

  <!-- ══════════════════════ PHILOSOPHY ══════════════════════ -->
  <div class="sc-section" style="padding-top:40px; padding-bottom: 0;">
    <div class="sc-manifesto">
      <span class="sc-eyebrow" style="display:block;margin-bottom:16px"
        >Philosophy</span
      >
      <p class="sc-manifesto-quote">
        "CSS has everything you need to build a <em>great UI</em>.<br />
        You just shouldn't have to write it <em>every time</em>."
      </p>
      <p
        style="font-size:15px;color:var(--color-muted);max-width:560px;margin:0 auto;line-height:1.7"
      >
        njX is built on the belief that a CSS library should be <strong
          style="color:var(--color-light)">invisible</strong
        > — no framework lock-in, no class name memorisation marathons, no config
        files. Just CSS custom properties doing what they were designed to do.
      </p>
    </div>
  </div>

  <!-- ══════════════════════ CTA ══════════════════════ -->
  <div class="sc-section" style="padding-top:0px;padding-bottom:20px">
    <div
      style="margin-top:56px;padding:40px;border-radius:20px;background:radial-gradient(ellipse 80% 100% at 50% 50%,color-mix(in srgb,var(--color-primary) 10%,transparent),transparent);border:1px solid color-mix(in srgb,var(--color-primary) 18%,transparent);text-align:center;max-width:1200px;margin-left:auto;margin-right:auto"
    >
      <h2 class="sc-heading" style="margin-bottom:16px">Ready to build?</h2>
      <p class="sc-subheading center" style="margin-bottom:40px">
        One line. Any HTML file. Any project. Start in under a minute.
      </p>
      <div style="display:flex;gap:14px;justify-content:center;flex-wrap:wrap">
        <a
          href={`${base}quickstart`}
          class="sc-btn-primary"
          style="font-size:16px;padding:16px 40px">Get Started — it's free</a
        >
        <a
          href={`${base}documentation`}
          class="sc-btn-ghost"
          style="font-size:16px;padding:16px 40px">Browse all components →</a
        >
      </div>
    </div>
  </div>
  <!-- ══ FOOTER ══ -->
  <PagesFooter activePage="overview" />
  <Bottombar activePage="overview" />
</BaseLayout>

<!-- ══════════════════════ STYLES ══════════════════════ -->
<style is:global>
  /* ── Reset ── */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  body {
    font-family: 'Inter', sans-serif;
    overflow-x: hidden;
  }
  a {
    color: inherit;
    text-decoration: none;
  }
  button {
    font-family: inherit;
    cursor: pointer;
    border: none;
    background: none;
    color: inherit;
  }
  .inp.inp-sm {
    font-size: 12px;
    background: var(--bg-main);
    border-radius: 12px;
    height: 35px;
    border: 1px solid var(--color-primary);
    padding: 0 5px;
    color: var(--color-light);
  }
  .wrap {
    max-width: 1340px;
    margin: 0 auto;
    padding: 0 32px;
  }

  /* ── HERO ── */
  .hero {
    position: relative;
    padding: 80px 0 80px;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 70% 60% at 30% 20%,
        color-mix(in srgb, var(--color-primary) 22%, transparent),
        transparent
      ),
      radial-gradient(
        ellipse 50% 50% at 80% 80%,
        color-mix(in srgb, var(--color-accent) 12%, transparent),
        transparent
      );
    pointer-events: none;
  }
  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 64px;
    align-items: center;
  }
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }
  .hero-left .label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 6px 14px;
    border-radius: 9999px;
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-primary) 25%, transparent);
    font-size: 11px;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 24px;
  }
  .hero-left .label .pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-primary);
    box-shadow: 0 0 10px var(--color-primary);
    animation: ov-pulse 1.8s infinite;
    flex-shrink: 0;
  }
  @keyframes ov-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }
  .hero-left h1 {
    font-family: 'Poppins', sans-serif;
    font-size: clamp(48px, 6vw, 84px);
    font-weight: 900;
    line-height: 0.95;
    letter-spacing: -0.025em;
    margin-bottom: 24px;
  }
  .hero-left h1 .grad {
    background: linear-gradient(
      135deg,
      var(--color-primary),
      var(--color-accent)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .hero-left h1 .dim {
    color: var(--color-muted);
  }
  .hero-left .sub {
    font-size: 18px;
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 480px;
    margin-bottom: 28px;
  }
  .hero-cta {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }
  .btn-pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 9999px;
    font-size: 14px;
    font-weight: 600;
    transition: all 0.2s;
    border: 1.5px solid transparent;
  }
  .btn-pill.primary {
    background: var(--color-primary);
    color: #fff;
  }
  .btn-pill.primary:hover {
    transform: scale(1.03);
    box-shadow: 0 6px 20px
      color-mix(in srgb, var(--color-primary) 40%, transparent);
  }
  .btn-pill.ghost {
    border-color: color-mix(in srgb, var(--color-neutral-600) 40%, transparent);
    color: var(--color-light);
  }
  .btn-pill.ghost:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
  }
  .stats-inline {
    display: flex;
    gap: 32px;
    flex-wrap: wrap;
  }
  .stats-inline > div {
    display: flex;
    flex-direction: column;
  }
  .stats-inline .v {
    font-family: 'Poppins', sans-serif;
    font-size: 28px;
    font-weight: 900;
    background: linear-gradient(
      135deg,
      var(--color-primary),
      var(--color-accent)
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .stats-inline .l {
    font-size: 11px;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 4px;
  }

  /* ── PLAYGROUND ── */
  .playground {
    background: var(--color-dark-secondary);
    border: 1px solid color-mix(in srgb, var(--color-primary) 25%, transparent);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
  }
  .pg-bar {
