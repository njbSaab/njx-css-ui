<script is:inline>
  (function initOvNew() {
    var tsw = document.getElementById('ov-tswatches');
    if (!tsw) return;

    // ── Central theme setter ──
    function ovnApplyTheme(t) {
      document.documentElement.setAttribute('data-theme', t);
      try {
        localStorage.setItem('njx-theme', t);
      } catch (e) {}
      var a1 = document.getElementById('ov-attr');
      if (a1) a1.textContent = 'data-theme="' + t + '"';
      var a2 = document.getElementById('ov-attr2');
      if (a2) a2.textContent = 'data-theme="' + t + '"';
      tsw.querySelectorAll('.s').forEach(function (el) {
        el.classList.toggle('on', el.dataset.t === t);
      });
      document.querySelectorAll('.sc-tpill').forEach(function (p) {
        p.classList.toggle('active', p.dataset.t === t);
      });
    }

    // ── Theme swatches ──
    var OV_THEMES = [
      ['dark', '#14a0ff'],
      ['light', '#94a3b8'],
      ['red', '#f43f5e'],
      ['blue', '#3b82f6'],
      ['green', '#22c55e'],
      ['cyan', '#00e5ff'],
      ['yellow', '#facc15'],
      ['pink', '#ec4899'],
      ['purple', '#a855f7'],
    ];
    var curTheme = (function () {
      try {
        return localStorage.getItem('njx-theme') || 'dark';
      } catch (e) {
        return 'dark';
      }
    })();

    OV_THEMES.forEach(function (pair) {
      var t = pair[0],
        c = pair[1];
      var s = document.createElement('span');
      s.className = 's' + (t === curTheme ? ' on' : '');
      s.style.background = c;
      s.dataset.t = t;
      s.title = t;
      s.onclick = function () {
        ovnApplyTheme(t);
      };
      tsw.appendChild(s);
    });

    // Sync attr labels to current theme
    var attrEl = document.getElementById('ov-attr');
    if (attrEl) attrEl.textContent = 'data-theme="' + curTheme + '"';
    var attrEl2 = document.getElementById('ov-attr2');
    if (attrEl2) attrEl2.textContent = 'data-theme="' + curTheme + '"';

    // Sync pills to current theme
    document.querySelectorAll('.sc-tpill').forEach(function (p) {
      p.classList.toggle('active', p.dataset.t === curTheme);
