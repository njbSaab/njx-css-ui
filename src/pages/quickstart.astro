---
import BaseLayout from '../layouts/BaseLayout.astro';
import PagesTopbar from '../components/PagesTopbar.astro';
import PagesFooter from '../components/PagesFooter.astro';
import Bottombar from '../components/Bottombar.astro';
import Demo from '../components/demo/Demo.astro';
import { LIB_VERSION, SIZE_FULL, SIZE_CLASSLESS } from '../lib/meta';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title="Quick Start — njX UI · One CDN link. Nine themes. Zero build tools."
  description="One CDN link. Nine themes ready to go. No bundler, no config. CDN in 30 seconds, npm in 60."
>
  <!-- ══ NAV ══ -->
  <PagesTopbar activePage="quickstart" />

  <!-- ══════════════════════ HERO ══════════════════════ -->
  <section class="qs-hero">
    <div class="qs-badge">⏱ 60-second install</div>
    <h1 class="qs-h1">
      <span class="qs-grad">Up and running</span><br />before your coffee.
    </h1>
    <p class="qs-sub">
      One CDN link. Nine themes ready to go. No bundler, no config.
    </p>
  </section>

  <!-- ══════════════════════ MODE BAR ══════════════════════ -->
  <div class="doc-mode-bar" id="qs-mode-bar">
    <span class="doc-mode-label">Mode</span>
    <div class="doc-mode-tabs">
      <button
        class="doc-mode-tab active"
        data-mode="full"
        onclick="qsSyncMode('full')"
      >
        <span class="doc-mode-icon">◈</span>
        njX UI Full
        <span class="doc-mode-default">RECOMMENDED</span>
        <span class="doc-mode-size">{SIZE_FULL}</span>
      </button>
      <button
        class="doc-mode-tab"
        data-mode="classless"
        onclick="qsSyncMode('classless')"
      >
        <span class="doc-mode-icon">&lt;/&gt;</span>
        Classless Only
        <span class="doc-mode-default">LITE</span>
        <span class="doc-mode-size">{SIZE_CLASSLESS}</span>
      </button>
      <button
        class="doc-mode-tab"
        data-mode="interactive"
        onclick="qsSyncMode('interactive')"
      >
        <span class="doc-mode-icon">JS</span>
        Interactive
      </button>
    </div>
    <span class="doc-mode-hint" id="qs-mode-hint"
      >Classless built-in — your HTML is styled automatically</span
    >
  </div>

  <!-- ══════════════════════ PATH SELECTOR ══════════════════════ -->
  <div class="qs-paths">
    <div class="qs-paths-row" id="qs-paths">
      <button class="on" data-p="cdn"
        ><span class="em">⚡</span>CDN <span style="opacity:0.7">· 30s</span
        ></button
      >
      <button data-p="npm"
        ><span class="em">📦</span>npm <span style="opacity:0.7">· 60s</span
        ></button
      >
      <button data-p="zip"
        ><span class="em">🗂</span>Download <span style="opacity:0.7"
          >· 90s</span
        ></button
      >
    </div>
  </div>

  <!-- ══════════════════════ TIMER ══════════════════════ -->
  <div class="qs-timer">
    <span>Progress</span>
    <div class="qs-timer-bar"><div id="qs-prog"></div></div>
    <span class="qs-clock" id="qs-clock">0/4</span>
  </div>

  <!-- ══════════════════════ TRACK ══════════════════════ -->
  <div class="qs-track" id="qs-track"></div>

  <!-- ══════════════════════ SUCCESS ══════════════════════ -->
  <div class="qs-success show" id="qs-success">
    <div class="qs-success-card">
      <div class="qs-success-em">🎉</div>
      <h3>You're shipping njX UI.</h3>
      <p>
        Every <code>.btn</code>, <code>.tag</code>, <code>.card</code> on your page
        now responds to <code>data-theme</code>. Want more?
      </p>
      <div class="qs-success-ctas">
        <a class="qs-b qs-b-p" href={`${base}overview`}
          >Browse 30+ components →</a
        >
        <a
          class="qs-b qs-b-g"
          href="https://github.com/njbSaab/njx-css-ui"
          target="_blank">Star on GitHub ★</a
        >
      </div>
    </div>
  </div>

  <!-- ══════════════════════ PANE ══════════════════════ -->
  <div class="qs3-pane">
    <div class="qs3-left">
      <section class="qs3-block" id="qs3-b1">
        <div class="qs3-n" data-n="1">Install</div>
        <h2>One line in your <span class="qs3-em">&lt;head&gt;</span>.</h2>

        <!-- Full / Interactive description -->
        <div data-qs-mode="full interactive">
          <p>
            njX UI is a single CSS file. Link it from a CDN, install via npm, or
            grab the ZIP. The rest of this page assumes the CDN path since it's
            the fastest.
          </p>
          <p>
            After the &lt;link&gt; loads you instantly have every <code
              >.btn</code
            >, <code>.inp</code>, <code>.tag</code>, <code>.card</code>, <code
              >.tip</code
            > and 20+ more classes available. No build. No bundler.
          </p>
        </div>
        <!-- Classless description -->
        <div data-qs-mode="classless" style="display:none">
          <p>
            <code>classless.min.css</code> — 47 KB, standalone. One link tag is all
            you need. No class names, no build step, no bundler.
          </p>
          <p>
            Every <code>&lt;button&gt;</code>, <code>&lt;input&gt;</code>,
            <code>&lt;table&gt;</code>, <code>&lt;details&gt;</code> is styled automatically
            through native HTML element selectors.
          </p>
        </div>

        <div class="qs3-tip">
          <div>
            <b>Tip</b><br />The CDN is cached on jsdelivr — 293&nbsp;KB on disk,
            ~40&nbsp;KB over the wire (gzip). Subsequent visitors hit your CDN
            cache or theirs.
          </div>
        </div>
      </section>

      <section class="qs3-block" id="qs3-b2">
        <div class="qs3-n" data-n="2">Theme</div>
        <h2>One attribute. <span class="qs3-em">Nine themes.</span></h2>
        <p>
          Set <code>data-theme</code> on &lt;html&gt; (or any wrapper — it's scoped
          to the subtree). Every component below that node re-tints automatically
          through inherited CSS custom properties.
        </p>
        <ul>
          <li><strong>dark</strong>Default. Electric blue on deep black.</li>
          <li><strong>light</strong>Inverted. Readable on white.</li>
          <li>
            <strong>red · blue · green · cyan · yellow · pink · purple</strong
            >Bold chromatic variants. Swap at any time.
          </li>
        </ul>
        <div class="qs3-tip">
          <div>
            <b>Persist it</b><br />Drop this before the library to remember the
            user's pick across reloads:<br /><code
              style="background:transparent;padding:0;color:#9ce700"
              >localStorage.getItem('theme') &amp;&amp;
              document.documentElement.setAttribute('data-theme',
              localStorage.getItem('theme'))</code
            >
          </div>
        </div>
      </section>

      <section class="qs3-block" id="qs3-b3">
        <!-- Full / Interactive: class composition -->
        <div data-qs-mode="full interactive">
          <div class="qs3-n" data-n="3">Compose</div>
          <h2>Stack classes like <span class="qs3-em">Lego</span>.</h2>
          <p>
            Every class is additive. Mix a <code>.btn</code> with <code
              >.btn-primary</code
            > for color, <code>.btn-sm</code> for size, and <code
              >.hover-glow</code
            > for the hover — all on one element.
          </p>
          <p>
            Same pattern for cards, inputs, tags, progress. There's no component
            "instance" to instantiate and no config file to edit — if you can
            write HTML, you're styling njX UI.
          </p>
          <ul>
            <li>
              <strong>Color</strong><code>.btn-primary</code>, <code
                >.btn-accent</code
              >, <code>.btn-success</code>, <code>.btn-error</code>, <code
                >.btn-ghost</code
              >, <code>.btn-outline</code>
            </li>
            <li>
              <strong>Size</strong><code>.btn-xs</code>, <code>.btn-sm</code>, <code
                >.btn-lg</code
              >, <code>.btn-xl</code>
            </li>
            <li>
              <strong>Hover</strong><code>.hover-grow</code>, <code
                >.hover-lift</code
              >, <code>.hover-glow</code>, <code>.hover-shimmer</code>, and 25
              more
            </li>
          </ul>
        </div>

        <!-- Classless: elements reference -->
        <div data-qs-mode="classless" style="display:none">
          <div class="qs3-n" data-n="3">Elements</div>
          <h2>Write HTML. <span class="qs3-em">It just works.</span></h2>
          <p>
            Every native HTML element below is styled automatically — no class
            names, no configuration. Classless mode styles the browser's default
            elements so your semantic markup looks great out of the box.
          </p>
          <ul>
            <li>
              <strong>Text</strong><code>&lt;h1&gt;</code>–<code
                >&lt;h6&gt;</code
              >, <code>&lt;p&gt;</code>, <code>&lt;blockquote&gt;</code>, <code
                >&lt;code&gt;</code
              >, <code>&lt;pre&gt;</code>
            </li>
            <li>
              <strong>Forms</strong><code>&lt;input&gt;</code>, <code
                >&lt;textarea&gt;</code
              >, <code>&lt;select&gt;</code>, <code>&lt;button&gt;</code>, <code
                >&lt;fieldset&gt;</code
              >
            </li>
            <li>
              <strong>Layout</strong><code>&lt;table&gt;</code>, <code
                >&lt;ul&gt;</code
              >, <code>&lt;ol&gt;</code>, <code>&lt;details&gt;</code>, <code
                >&lt;nav&gt;</code
              >
            </li>
          </ul>
          <div class="qs3-tip">
            <div>
              <b>Want component classes?</b><br />Switch to <strong>Full</strong
              > mode. Add <code>classless-mode.css</code> + <code
                >data-classless</code
              > on
              <code>&lt;html&gt;</code> to get bare element styles <em>plus</em> all
              30+ component classes.
            </div>
          </div>
        </div>
      </section>

      <section class="qs3-block" id="qs3-b4">
        <div class="qs3-n" data-n="4">Brand it</div>
        <h2>Override <span class="qs3-em">one variable</span>.</h2>
        <p>
          You don't need to ship a custom theme. Drop a <code>:root</code> override
          in your own stylesheet and every component on the page retints. The default
          palette is nine CSS custom properties; override them to match your brand.
        </p>
        <p>
          Want scoped branding? Apply the same override to a wrapper element
          instead of <code>:root</code>. Anything inside inherits — anything
          outside keeps the default.
        </p>
        <div class="qs3-tip">
          <div>
            <b>Full tokens list</b><br />60+ variables live in the <code
              >_base.css</code
            > file — colors, radii, shadows, font stacks, ease curves. Every one is
            overridable.
          </div>
        </div>
      </section>
    </div>

    <div class="qs3-right">
      <div class="qs3-code-card" id="qs3-ccard">
        <div class="qs3-code-bar">
          <div class="qs3-code-dots">
            <span class="qs3-d" style="background:#ff5f57"></span>
            <span class="qs3-d" style="background:#febc2e"></span>
            <span class="qs3-d" style="background:#28c840"></span>
          </div>
          <span class="qs3-code-fname" id="qs3-cfname">index.html</span>
          <span class="qs3-code-lang" id="qs3-clang">HTML</span>
        </div>
        <div class="qs3-code-tabs" id="qs3-ctabs"></div>
        <div class="qs3-code-body" id="qs3-cbody">
          <button class="qs3-code-copy" id="qs3-ccopy">Copy</button>
          <pre id="qs3-cpre"></pre>
        </div>
        <div class="qs3-preview-toggle">
          <button id="qs3-tb-code" class="on">code</button>
          <button id="qs3-tb-both">code + preview</button>
        </div>
        <div class="qs3-preview-body" id="qs3-cpreview"></div>
      </div>
    </div>
  </div>

  <!-- ══════════════════════ CALLOUT ══════════════════════ -->
  <section class="qs3-callout">
    <div class="qs3-callout-card">
      <div>
        <h3>That's the whole tour.</h3>
        <p>
          30+ components, 9 themes, animations, hovers, gradients — all
          available from the same CSS file you already linked.
        </p>
      </div>
      <div class="qs3-ctas">
        <a href={`${base}overview`} class="qs3-btn-pill qs3-p"
          >Browse Components →</a
        >
        <a
          href="https://github.com/njbSaab/njx-css-ui"
          target="_blank"
          class="qs3-btn-pill qs3-g">★ Star on GitHub</a
        >
      </div>
    </div>
  </section>

  <!-- ══════════════════════ FROM ZERO ══════════════════════ -->
  <div class="sc-section" style="padding-top:48px;padding-bottom:48px">
    <span class="sc-eyebrow">Your first page</span>
    <h2 class="sc-heading">From zero to styled<br />in 3 steps</h2>
    <div class="sc-two-col" style="margin-top:24px;align-items:stretch">
      <div class="sc-steps">
        <div class="sc-step">
          <div class="sc-step-left">
            <div class="sc-step-num">1</div>
            <div class="sc-step-line"></div>
          </div>
          <div class="sc-step-body">
            <div class="sc-step-title">Connect the stylesheet</div>
            <div class="sc-step-desc">
              One <code>&lt;link&gt;</code> tag inside <code>&lt;head&gt;</code
              >. No JavaScript, no build step, nothing else required.
            </div>
            <div class="sc-code-wrap" style="margin-top:10px">
              <div
                class="sc-code-body"
                style="padding:14px 18px;font-size:12px"
              >
                <span class="k">&lt;link</span>
                <span class="t">rel</span>=<span class="s">"stylesheet"</span>
                <span class="t">href</span>=<span class="s"
                  >"https://cdn.jsdelivr.net/npm/njx-css-ui@1.1.0/css/<span
                    data-qs-cssfile>style.min.css</span
                  >"</span
                ><span class="k">&gt;</span>
              </div>
            </div>
          </div>
        </div>
        <div class="sc-step">
          <div class="sc-step-left">
            <div class="sc-step-num">2</div>
            <div class="sc-step-line"></div>
          </div>
          <div class="sc-step-body">
            <div class="sc-step-title">Pick a theme</div>
            <div class="sc-step-desc">
              Set <code>data-theme</code> on the <code>&lt;html&gt;</code> element.
              Every component adapts automatically — no extra CSS needed.
            </div>
            <div class="sc-code-wrap" style="margin-top:10px">
              <div
                class="sc-code-body"
                style="padding:14px 18px;font-size:12px"
              >
                <span class="k">&lt;html</span>
                <span class="t">lang</span>=<span class="s">"en"</span>
                <span class="t">data-theme</span>=<span class="s">"dark"</span
                ><span class="k">&gt;</span>
                <span class="c"
                  >&lt;!-- dark · light · red · blue · green · cyan · yellow ·
                  pink · purple --&gt;</span
                >
              </div>
            </div>
          </div>
        </div>
        <!-- Step 3: Full / Interactive -->
        <div class="sc-step" data-qs-mode="full interactive">
          <div class="sc-step-left">
            <div class="sc-step-num">3</div>
          </div>
          <div class="sc-step-body">
            <div class="sc-step-title">Use component classes</div>
            <div class="sc-step-desc">
              Add classes like <code>btn btn-primary</code> or <code>card</code
              >. That's the whole API — just class names on HTML elements.
            </div>
            <div class="sc-code-wrap" style="margin-top:10px">
              <div
                class="sc-code-body"
                style="padding:14px 18px;font-size:12px"
              >
                <span class="k">&lt;button</span>
                <span class="t">class</span>=<span class="s"
                  >"btn btn-primary"</span
                ><span class="k">&gt;</span>Click me<span class="k"
                  >&lt;/button&gt;</span
                ><br /><span class="k">&lt;div</span>
                <span class="t">class</span>=<span class="s">"card"</span><span
                  class="k">&gt;</span
                >A styled card<span class="k">&lt;/div&gt;</span><br /><span
                  class="k">&lt;span</span
                >
                <span class="t">class</span>=<span class="s"
                  >"tag tag-primary"</span
                ><span class="k">&gt;</span>Badge<span class="k"
                  >&lt;/span&gt;</span
                >
              </div>
            </div>
          </div>
        </div>
        <!-- Step 3: Classless -->
        <div class="sc-step" data-qs-mode="classless" style="display:none">
          <div class="sc-step-left">
            <div class="sc-step-num">3</div>
          </div>
          <div class="sc-step-body">
            <div class="sc-step-title">Write semantic HTML</div>
            <div class="sc-step-desc">
              No class names needed. Every native HTML element is styled
              automatically —
              <code>&lt;button&gt;</code>, <code>&lt;input&gt;</code>,
              <code>&lt;table&gt;</code>, <code>&lt;details&gt;</code> and more.
            </div>
            <div class="sc-code-wrap" style="margin-top:10px">
              <div
                class="sc-code-body"
                style="padding:14px 18px;font-size:12px"
              >
                <span class="k">&lt;button&gt;</span>Click me<span class="k"
                  >&lt;/button&gt;</span
                ><br />
                <span class="k">&lt;input</span>
                <span class="t">type</span>=<span class="s">"text"</span>
                <span class="t">placeholder</span>=<span class="s">"email"</span
                ><span class="k">&gt;</span><br />
                <span class="k">&lt;details&gt;&lt;summary&gt;</span>FAQ<span
                  class="k">&lt;/summary&gt;</span
                >Answer<span class="k">&lt;/details&gt;</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column">
        <div
          style="font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--color-muted);margin-bottom:12px"
        >
          Complete boilerplate
        </div>
        <div
          class="sc-code-wrap"
          style="flex:1;display:flex;flex-direction:column"
        >
          <div class="sc-code-header">
            <div class="sc-code-dots">
              <div class="sc-code-dot" style="background:#ff5f57"></div>
              <div class="sc-code-dot" style="background:#febc2e"></div>
              <div class="sc-code-dot" style="background:#28c840"></div>
            </div>
            <span class="sc-code-filename">index.html</span>
            <button class="sc-code-copy" id="qs-boilerplate-copy">Copy</button>
          </div>
          <div
            class="sc-code-body"
            id="qs-boilerplate-code"
            style="padding:20px 22px;flex:1;overflow-y:auto"
          >
            <!-- Full / Interactive boilerplate -->
            <span data-qs-mode="full interactive"
              ><span class="k">&lt;!DOCTYPE html&gt;</span><br /><span class="k"
                >&lt;html</span
              >
              <span class="t">lang</span>=<span class="s">"en"</span>
              <span class="t">data-theme</span>=<span class="s">"dark"</span
              ><span class="k">&gt;</span><br /><span class="k"
                >&lt;head&gt;</span
              ><br />&nbsp;&nbsp;<span class="k">&lt;meta</span>
              <span class="t">charset</span>=<span class="s">"UTF-8"</span><span
                class="k">&gt;</span
              ><br />&nbsp;&nbsp;<span class="k">&lt;meta</span>
              <span class="t">name</span>=<span class="s">"viewport"</span>
              <span class="t">content</span>=<span class="s"
                >"width=device-width, initial-scale=1"</span
              ><span class="k">&gt;</span><br />&nbsp;&nbsp;<span class="k"
                >&lt;link</span
              >
              <span class="t">rel</span>=<span class="s">"stylesheet"</span><br
              />&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t"
                >href</span
              >=<span class="s"
                >"https://cdn.jsdelivr.net/npm/njx-css-ui@1.1.0/css/<span
                  data-qs-cssfile>style.min.css</span
                >"</span
              ><span class="k">&gt;</span><br />&nbsp;&nbsp;<span class="k"
                >&lt;title&gt;</span
              >My App<span class="k">&lt;/title&gt;</span><br /><span class="k"
                >&lt;/head&gt;</span
              ><br /><span class="k">&lt;body&gt;</span><br /><br
              />&nbsp;&nbsp;<span class="k">&lt;button</span>
              <span class="t">class</span>=<span class="s"
                >"btn btn-primary"</span
              ><span class="k">&gt;</span>Get Started<span class="k"
                >&lt;/button&gt;</span
              ><br /><br />&nbsp;&nbsp;<span class="k">&lt;div</span>
              <span class="t">class</span>=<span class="s">"card-glow"</span
              ><span class="k">&gt;</span><br />&nbsp;&nbsp;&nbsp;&nbsp;<span
                class="k">&lt;h2</span
              >
              <span class="t">class</span>=<span class="s"
                >"text-gradient-primary"</span
              ><span class="k">&gt;</span>Hello njX<span class="k"
                >&lt;/h2&gt;</span
              ><br />&nbsp;&nbsp;&nbsp;&nbsp;<span class="k">&lt;p</span>
              <span class="t">class</span>=<span class="s">"text-muted"</span
              ><span class="k">&gt;</span>Built in 30 seconds.<span class="k"
                >&lt;/p&gt;</span
              ><br />&nbsp;&nbsp;<span class="k">&lt;/div&gt;</span><br /><br
              /><span class="k">&lt;/body&gt;</span><br /><span class="k"
                >&lt;/html&gt;</span
              ></span
            >
            <!-- Classless boilerplate -->
            <span data-qs-mode="classless" style="display:none"
              ><span class="k">&lt;!DOCTYPE html&gt;</span><br /><span class="k"
                >&lt;html</span
              >
              <span class="t">lang</span>=<span class="s">"en"</span>
              <span class="t">data-theme</span>=<span class="s">"dark"</span
              ><span class="k">&gt;</span><br /><span class="k"
                >&lt;head&gt;</span
              ><br />&nbsp;&nbsp;<span class="k">&lt;meta</span>
              <span class="t">charset</span>=<span class="s">"UTF-8"</span><span
                class="k">&gt;</span
              ><br />&nbsp;&nbsp;<span class="k">&lt;meta</span>
              <span class="t">name</span>=<span class="s">"viewport"</span>
              <span class="t">content</span>=<span class="s"
                >"width=device-width, initial-scale=1"</span
              ><span class="k">&gt;</span><br />&nbsp;&nbsp;<span class="k"
                >&lt;link</span
              >
              <span class="t">rel</span>=<span class="s">"stylesheet"</span><br
              />&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="t"
                >href</span
              >=<span class="s"
                >"https://cdn.jsdelivr.net/npm/njx-css-ui@1.1.0/css/<span
                  data-qs-cssfile>classless.min.css</span
                >"</span
              ><span class="k">&gt;</span><br />&nbsp;&nbsp;<span class="k"
                >&lt;title&gt;</span
              >My App<span class="k">&lt;/title&gt;</span><br /><span class="k"
                >&lt;/head&gt;</span
              ><br /><span class="k">&lt;body&gt;</span><br /><br
              />&nbsp;&nbsp;<span class="k">&lt;h1&gt;</span>Hello njX<span
                class="k">&lt;/h1&gt;</span
              ><br />&nbsp;&nbsp;<span class="k">&lt;p&gt;</span>No class names
              needed.<span class="k">&lt;/p&gt;</span><br />&nbsp;&nbsp;<span
                class="k">&lt;button&gt;</span
              >Get Started<span class="k">&lt;/button&gt;</span><br
              />&nbsp;&nbsp;<span class="k">&lt;input</span>
