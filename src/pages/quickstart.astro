  &lt;<span class="sh-tag">summary</span>&gt;FAQ item&lt;/<span class="sh-tag">summary</span>&gt;
  Answer text here.
&lt;/<span class="sh-tag">details</span>&gt;
&lt;<span class="sh-tag">table</span>&gt;
  &lt;<span class="sh-tag">tr</span>&gt;&lt;<span class="sh-tag">th</span>&gt;Name&lt;/<span class="sh-tag">th</span>&gt;&lt;<span class="sh-tag">th</span>&gt;Role&lt;/<span class="sh-tag">th</span>&gt;&lt;/<span class="sh-tag">tr</span>&gt;
  &lt;<span class="sh-tag">tr</span>&gt;&lt;<span class="sh-tag">td</span>&gt;Alice&lt;/<span class="sh-tag">td</span>&gt;&lt;<span class="sh-tag">td</span>&gt;Dev&lt;/<span class="sh-tag">td</span>&gt;&lt;/<span class="sh-tag">tr</span>&gt;
&lt;/<span class="sh-tag">table</span>&gt;`,
              preview: `<details><summary>FAQ item</summary><p style="margin:4px 0">Answer text.</p></details>`,
            },
          ],
        },
        b4: {
          title: 'Brand it',
          fname: 'brand.css',
          tabs: [
            {
              k: 'root',
              name: ':root',
              lang: 'CSS',
              code: `<span class="sh-tag">:root</span> { <span class="attr">--color-primary</span>: <span class="str">#ff6b35</span>; }`,
              preview: `<div style="--color-primary:#ff6b35;display:flex;gap:8px"><button class="btn btn-primary btn-sm">Primary</button></div>`,
            },
            {
              k: 'scoped',
              name: 'Scoped',
              lang: 'HTML',
              code: `&lt;<span class="sh-tag">section</span> <span class="attr">style</span>=<span class="str">"--color-primary:#ff6b35"</span>&gt;&lt;/<span class="sh-tag">section</span>&gt;`,
              preview: `<button class="btn btn-primary btn-sm">Default</button> <span style="--color-primary:#ff6b35"><button class="btn btn-primary btn-sm">Branded</button></span>`,
            },
            {
              k: 'tokens',
              name: 'All tokens',
              lang: 'CSS',
              code: `<span class="com">/* 60+ tokens in _base.css */</span>`,
              preview: `<div style="font-family:'Roboto Mono',monospace;font-size:12px;color:var(--color-muted)">60+ tokens</div>`,
            },
          ],
        },
      };

      var preEl2 = document.getElementById('qs3-cpre');
      var previewEl2 = document.getElementById('qs3-cpreview');
      var fnameEl2 = document.getElementById('qs3-cfname');
      var langEl2 = document.getElementById('qs3-clang');
      var card2 = document.getElementById('qs3-ccard');
      var curBlock2 = 'b1',
        curTab2 = 0;

      function renderTabs2() {
        var b = BLOCKS2[curBlock2];
        var useClassless = window._qsMode === 'classless';
        var tabs2 = useClassless && b.classlessTabs ? b.classlessTabs : b.tabs;
        tabsEl2.innerHTML = '';
        tabs2.forEach(function (t, i) {
          var btn = document.createElement('button');
          btn.className = i === curTab2 ? 'on' : '';
          btn.textContent = t.name;
          btn.onclick = function () {
            curTab2 = i;
            renderTab2();
          };
          tabsEl2.appendChild(btn);
        });
        renderTab2();
      }
      function renderTab2() {
        var b = BLOCKS2[curBlock2];
        var useClassless = window._qsMode === 'classless';
        var tabs2 = useClassless && b.classlessTabs ? b.classlessTabs : b.tabs;
        var t = tabs2[curTab2] || tabs2[0];
        preEl2.innerHTML =
          useClassless && t.classlessCode ? t.classlessCode : t.code;
        if (window._qsApplyModeToCode) window._qsApplyModeToCode(preEl2);
        fnameEl2.textContent = t.fname || b.fname;
        langEl2.textContent = t.lang || 'HTML';
        previewEl2.innerHTML =
          useClassless && t.classlessPreview
            ? t.classlessPreview
            : t.preview || '';
        if (t.themePreview) {
          previewEl2.innerHTML =
            '<button class="btn btn-primary btn-sm">Primary</button> <span class="tag tag-primary">live</span>';
          previewEl2.setAttribute('data-theme', t.themePreview);
        } else {
          previewEl2.removeAttribute('data-theme');
        }
        Array.from(tabsEl2.children).forEach(function (c, i) {
          c.classList.toggle('on', i === curTab2);
        });
      }

      var blocks2 = Array.from(document.querySelectorAll('.qs3-block'));
      var io2 = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (e) {
            if (e.isIntersecting && e.intersectionRatio > 0.3) {
              var id = e.target.id.replace('qs3-', '');
              if (curBlock2 !== id) {
                curBlock2 = id;
                curTab2 = 0;
                renderTabs2();
              }
            }
          });
        },
        { threshold: [0.3, 0.6], rootMargin: '-80px 0px -50% 0px' },
      );
      blocks2.forEach(function (b) {
        io2.observe(b);
      });

      var tbCode2 = document.getElementById('qs3-tb-code');
      var tbBoth2 = document.getElementById('qs3-tb-both');
      if (tbCode2)
        tbCode2.onclick = function () {
          card2.classList.remove('show-preview');
          tbCode2.classList.add('on');
          tbBoth2.classList.remove('on');
        };
      if (tbBoth2)
        tbBoth2.onclick = function () {
          card2.classList.add('show-preview');
          tbBoth2.classList.add('on');
          tbCode2.classList.remove('on');
        };

      var ccopy2 = document.getElementById('qs3-ccopy');
      if (ccopy2)
        ccopy2.onclick = function () {
          if (navigator.clipboard)
            navigator.clipboard.writeText(preEl2.innerText);
          ccopy2.textContent = 'Copied!';
          setTimeout(function () {
            ccopy2.textContent = 'Copy';
          }, 1500);
        };

      renderTabs2();
      window._qsRenderTab2 = renderTabs2;
    })();
  });

  // ══════════════════════ MODE BAR ══════════════════════
  var QS_MODE_HINTS = {
    full: 'Classless built-in — your HTML is styled automatically',
    classless: 'Standalone — no component classes, 47 KB',
    interactive: 'Full library + JS: modals, tabs, toasts and more',
  };
  var QS_CSS_FILE = {
    full: 'style.min.css',
    classless: 'classless.min.css',
    interactive: 'style.min.css',
  };

  function qsSyncMode(flavor) {
    // 1. Sync mode bar tabs
    document
      .querySelectorAll('#qs-mode-bar .doc-mode-tab')
      .forEach(function (b) {
        b.classList.toggle('active', b.dataset.mode === flavor);
      });
    // 2. Update hint
    var hint = document.getElementById('qs-mode-hint');
    if (hint) hint.textContent = QS_MODE_HINTS[flavor] || QS_MODE_HINTS.full;

    // 3. Update global mode + css file vars (used by PATHS getters and render hooks)
    window._qsMode = flavor;
    window._qsCssFile = QS_CSS_FILE[flavor] || 'style.min.css';

    // 4. Define code transformation hook (used by renderTab / renderTab2)
    var _cssFile = window._qsCssFile;
    window._qsApplyModeToCode = function (el) {
      if (!el) return;
      el.innerHTML = el.innerHTML.replace(/style\.min\.css/g, _cssFile);
    };

    // 5. Re-render the progress tracker with correct PATHS
    if (window._qsRender) window._qsRender();

    // 6. Re-render code card (applies hook automatically via renderTab/renderTab2)
    if (window._qsRenderTab) window._qsRenderTab();
    if (window._qsRenderTab2) window._qsRenderTab2();

    // 7. Update static data-qs-cssfile spans
    document.querySelectorAll('[data-qs-cssfile]').forEach(function (el) {
      el.textContent = window._qsCssFile;
    });

    // 8. Show/hide data-qs-mode blocks (static HTML sections)
    document.querySelectorAll('[data-qs-mode]').forEach(function (el) {
      var modes = el.dataset.qsMode.split(' ');
      el.style.display = modes.indexOf(flavor) !== -1 ? '' : 'none';
    });

    // 9. Show/hide JS step (interactive only)
    document.querySelectorAll('[data-qs-jsonly]').forEach(function (el) {
      el.style.display = flavor === 'interactive' ? '' : 'none';
    });

    // 10. Save
    try {
      localStorage.setItem('njx-flavor', flavor);
    } catch (e) {}
  }

  // Init from localStorage (shared with docs page)
  (function () {
    var saved = 'full';
    try {
      saved = localStorage.getItem('njx-flavor') || 'full';
    } catch (e) {}
    if (saved !== 'full') qsSyncMode(saved);
  })();
  document.addEventListener('astro:page-load', function () {
    var saved = 'full';
    try {
      saved = localStorage.getItem('njx-flavor') || 'full';
    } catch (e) {}
    qsSyncMode(saved);
  });
</script>
