    var curP = 'cdn';
    var done = {};

    function render() {
      var activePaths =
        window._qsMode === 'classless' ? CLASSLESS_PATHS : PATHS;
      var steps = activePaths[curP] || activePaths['cdn'];
      track.innerHTML = '';
      steps.forEach(function (st, i) {
        var isDone = !!done[curP + '-' + i];
        var isActive = !isDone && (i === 0 || !!done[curP + '-' + (i - 1)]);
        var el = document.createElement('div');
        el.className =
          'qs-step' + (isDone ? ' done' : '') + (isActive ? ' active' : '');
        el.innerHTML =
          '<div class="num"><span>' +
          (i + 1) +
          '</span></div>' +
          '<div class="body">' +
          '<div class="h">' +
          st.h +
          '<span class="meta">' +
          st.meta +
          '</span></div>' +
          '<div class="d">' +
          st.d +
          '</div>' +
          (st.dl
            ? '<a class="qs-dl-btn" href="' +
              st.dl +
              '" download>⬇ Download njx-css-ui.zip</a>'
            : '<div class="code"><button class="copy">Copy</button><pre>' +
              st.code +
              '</pre></div>') +
          '<div class="actions">' +
          '<button class="check" data-i="' +
          i +
          '">' +
          (isDone ? st.check : 'I did this →') +
          '</button>' +
          (isDone
            ? ''
            : '<button class="skip" data-i="' + i + '">Skip</button>') +
          '</div>' +
          '</div>';
        track.appendChild(el);
      });

      track.querySelectorAll('.check, .skip').forEach(function (b) {
        b.onclick = function () {
          done[curP + '-' + b.dataset.i] = true;
          updateProgress();
        };
      });
      track.querySelectorAll('.copy').forEach(function (b) {
        b.onclick = function () {
          var txt = this.parentElement.querySelector('pre').innerText;
          if (navigator.clipboard) navigator.clipboard.writeText(txt);
          this.textContent = 'Copied!';
          var self = this;
          setTimeout(function () {
            self.textContent = 'Copy';
          }, 1500);
        };
      });
      updateProgress();
    }

    function updateProgress() {
      var activePaths =
        window._qsMode === 'classless' ? CLASSLESS_PATHS : PATHS;
      var steps = activePaths[curP] || activePaths['cdn'];
      var completed = steps.reduce(function (n, _, i) {
        return n + (done[curP + '-' + i] ? 1 : 0);
      }, 0);
      var prog = document.getElementById('qs-prog');
      var clock = document.getElementById('qs-clock');
      var success = document.getElementById('qs-success');
      if (prog) prog.style.width = (completed / steps.length) * 100 + '%';
      if (clock) clock.textContent = completed + '/' + steps.length;
      if (success) success.classList.toggle('show', completed === steps.length);

      track.querySelectorAll('.qs-step').forEach(function (el, i) {
        var isDone = !!done[curP + '-' + i];
        var isActive = !isDone && (i === 0 || !!done[curP + '-' + (i - 1)]);
        el.classList.toggle('done', isDone);
        el.classList.toggle('active', isActive);
        var cb = el.querySelector('.check');
        if (cb) cb.textContent = isDone ? steps[i].check : 'I did this →';
        var sk = el.querySelector('.skip');
        if (sk && isDone) sk.remove();
      });
    }

    document.querySelectorAll('#qs-paths button').forEach(function (b) {
      b.onclick = function () {
        document.querySelectorAll('#qs-paths button').forEach(function (x) {
          x.classList.remove('on');
        });
        b.classList.add('on');
        curP = b.dataset.p;
        done = {};
        render();
      };
    });

    render();
    window._qsRender = function () {
      done = {};
      render();
    };
    window._qsClasslessPaths = CLASSLESS_PATHS;

    // ── Boilerplate copy ──
    var bpCopy = document.getElementById('qs-boilerplate-copy');
    if (bpCopy)
      bpCopy.onclick = function () {
        var el = document.getElementById('qs-boilerplate-code');
        if (el && navigator.clipboard) {
          var children = el.querySelectorAll('[data-qs-mode]');
          var src = el;
          for (var i = 0; i < children.length; i++) {
            if (children[i].style.display !== 'none') {
              src = children[i];
              break;
            }
          }
          navigator.clipboard.writeText(src.innerText);
        }
        bpCopy.textContent = 'Copied!';
        setTimeout(function () {
          bpCopy.textContent = 'Copy';
        }, 1500);
      };
  })();

