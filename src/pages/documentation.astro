                        <span class="c">/* Via HTML attribute */</span>
                        <span class="k">&lt;html</span>
                        <span class="t">data-theme</span>=<span class="s"
                            >"purple"</span
                        ><span class="k">&gt;</span>

                        <span class="c">/* Via JavaScript */</span>
                        <span class="v">document</span><span class="p">.</span
                        ><span class="t">documentElement</span><span class="p"
                            >.</span
                        ><span class="v">setAttribute</span><span class="p"
                            >(</span
                        ><span class="s">'data-theme'</span><span class="p"
                            >,</span
                        >
                        <span class="s">'purple'</span><span class="p">);</span>

                        <span class="c"
                            >/* With localStorage persistence */</span
                        >
                        <span class="k">function</span>
                        <span class="v">setTheme</span><span class="p">(</span
                        ><span class="t">name</span><span class="p"
                            >) {}
                            <span class="v">document</span><span class="p"
                                >.</span
                            ><span class="t">documentElement</span><span
                                class="p">.</span
                            ><span class="v">setAttribute</span><span class="p"
                                >(</span
                            ><span class="s">'data-theme'</span><span class="p"
                                >,</span
                            >
                            <span class="t">name</span><span class="p">);</span>
                            <span class="v">localStorage</span><span class="p"
                                >.</span
                            ><span class="v">setItem</span><span class="p"
                                >(</span
                            ><span class="s">'theme'</span><span class="p"
                                >,</span
                            >
                            <span class="t">name</span><span class="p">);</span>
                            <span class="p"></span></span
                        >
                        <span class="k">const</span>
                        <span class="t">saved</span>
                        <span class="p">=</span>
                        <span class="v">localStorage</span><span class="p"
                            >.</span
                        ><span class="v">getItem</span><span class="p">(</span
                        ><span class="s">'theme'</span><span class="p">);</span>
                        <span class="k">if</span>
                        <span class="p">(</span><span class="t">saved</span
                        ><span class="p">)</span>
                        <span class="v">setTheme</span><span class="p">(</span
                        ><span class="t">saved</span><span class="p">);</span>
