<!-- ── quickstart-specific styles (is:global = no Astro scoping) ── -->
<style is:global>
    *,
    *::before,
    *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--сolor-dark);
        color: var(--color-light);
        font-family: 'Roboto', sans-serif;
        min-height: 100vh;
        transition:
            background 0.35s,
            color 0.35s;
        overflow-x: hidden;
    }

    .lib-sidebar .sc-nav-github {
        background: var(--сolor-dark) !important;
        box-shadow: none !important;
    }

    /* ── DOC LAYOUT ── */
    .doc-layout {
        display: grid;
        grid-template-columns: 260px 1fr;
        min-height: calc(100vh - 60px);
        max-width: 1400px;
        margin: 0 auto;
    }

    /* ── SIDEBAR ── */
    .doc-sidebar {
        position: sticky;
        top: 60px;
        height: calc(100vh - 60px);
        overflow-y: auto;
        padding: 32px 20px 40px;
        border-right: 1px solid
            color-mix(in srgb, var(--color-neutral-600) 18%, transparent);
    }

    .doc-sidebar::-webkit-scrollbar {
        width: 4px;
    }

    .doc-sidebar::-webkit-scrollbar-track {
        background: transparent;
    }

    .doc-sidebar::-webkit-scrollbar-thumb {
        background: color-mix(
            in srgb,
            var(--color-neutral-600) 35%,
            transparent
        );
        border-radius: 4px;
    }

    .doc-sidebar-group {
        margin-bottom: 28px;
    }

    .doc-sidebar-label {
        font-size: 10px;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        color: var(--color-muted);
        opacity: 0.5;
        padding: 0 12px;
        margin-bottom: 6px;
        display: block;
    }

    .doc-sidebar a {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
        color: var(--color-muted);
        text-decoration: none;
        transition: all 0.18s;
        margin-bottom: 2px;
    }

    .doc-sidebar a:hover {
        color: var(--color-light);
        background: color-mix(in srgb, var(--color-primary) 8%, transparent);
    }

    .doc-sidebar a.active,
    .lib-sidebar a[href^='#'].active {
        color: var(--color-primary);
        background: color-mix(in srgb, var(--color-primary) 12%, transparent);
        font-weight: 600;
    }

    .doc-sidebar a .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: currentColor;
        flex-shrink: 0;
        opacity: 0.5;
    }

    .doc-sidebar a.active .dot {
        opacity: 1;
    }

    /* ── MAIN CONTENT ── */
    .doc-main {
        padding: 0 56px 80px;
        min-width: 0;
    }

    /* ── SECTION ── */
    .doc-section {
        margin-bottom: 72px;
        scroll-margin-top: 80px;
    }

    .doc-section-header {
        margin-bottom: 32px;
    }

    .sc-eyebrow {
        display: inline-block;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 2px;
        color: var(--color-primary);
        margin-bottom: 10px;
    }

    .sc-heading {
        font-size: clamp(22px, 3vw, 34px);
        font-weight: 900;
        letter-spacing: -1.2px;
        line-height: 1.1;
        margin-bottom: 12px;
    }

    .sc-subheading {
        font-size: 15px;
        color: var(--color-muted);
        line-height: 1.7;
        max-width: 640px;
    }

    .doc-divider {
        height: 1px;
        background: color-mix(
            in srgb,
            var(--color-neutral-600) 18%,
            transparent
        );
        margin-bottom: 72px;
    }

    /* ── CODE BLOCK ── */
    .sc-code-wrap {
        background: #0d0d0d;
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid #222;
        margin-top: 16px;
    }

    .sc-code-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 10px 18px;
        background: #111;
        border-bottom: 1px solid #222;
    }

    .sc-code-dots {
        display: flex;
        gap: 6px;
    }

    .sc-code-dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
    }

    .sc-code-filename {
        font-size: 12px;
        font-family: 'Roboto Mono', monospace;
        color: #555;
    }

    .sc-code-copy {
        font-size: 11px;
        font-weight: 600;
        padding: 3px 10px;
        border-radius: 6px;
        background: #222;
        border: 1px solid #333;
        color: #888;
        cursor: pointer;
        transition: all 0.2s;
    }

    .sc-code-copy:hover {
        background: #333;
        color: #fff;
    }

    .sc-code-body {
        padding: 20px 22px;
        font-family: 'Roboto Mono', monospace;
        font-size: 12.5px;
        line-height: 1.9;
        overflow-x: auto;
    }

    .sc-code-body .c {
        color: #555;
        font-style: italic;
    }

    .sc-code-body .k {
        color: #e06c75;
    }

    .sc-code-body .s {
        color: #98c379;
    }

    .sc-code-body .v {
        color: #61afef;
    }

    .sc-code-body .n {
        color: #c678dd;
    }

    .sc-code-body .t {
        color: #e5c07b;
    }

    .sc-code-body .p {
        color: #abb2bf;
    }

    .sc-code-body .ok {
        color: #98c379;
    }

    .sc-code-body .err {
        color: #e06c75;
    }

    code {
        font-family: 'Roboto Mono', monospace;
        font-size: 0.87em;
        background: color-mix(in srgb, var(--color-primary) 10%, transparent);
        color: var(--color-primary);
        padding: 2px 6px;
        border-radius: 5px;
    }

    /* ── CARDS GRID ── */
    .doc-grid {
        display: grid;
        gap: 12px;
    }

    .doc-grid-2 {
        grid-template-columns: 1fr 1fr;
    }

    .doc-grid-3 {
        grid-template-columns: repeat(3, 1fr);
    }

    .doc-grid-auto {
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    }

    .doc-grid-tokens {
        grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }

    .doc-card {
        padding: 16px 18px;
        border-radius: 12px;
        border: 1px solid
            color-mix(in srgb, var(--color-neutral-600) 25%, transparent);
        background: var(--color-dark-secondary);
    }

    .doc-card-title {
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .doc-card-mono {
        font-family: 'Roboto Mono', monospace;
        font-size: 11px;
        color: var(--color-muted);
        line-height: 1.7;
    }

    /* ── THEME SWATCHES ── */
    .doc-themes-grid {
        display: grid;
        grid-template-columns: repeat(9, 1fr);
        gap: 10px;
    }

    .doc-theme-swatch {
        border-radius: 12px;
        overflow: hidden;
        cursor: pointer;
        border: 2px solid transparent;
        transition: all 0.2s;
    }

    .doc-theme-swatch:hover {
        transform: translateY(-3px);
        border-color: var(--color-primary);
    }

    .doc-theme-swatch.selected {
        border-color: white;
        box-shadow: 0 6px 20px rgba(0, 0, 0, 0.4);
    }

    .doc-theme-top {
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .doc-theme-dot-b {
        width: 18px;
        height: 18px;
        border-radius: 50%;
    }

    .doc-theme-name {
        padding: 7px 4px;
        text-align: center;
        font-size: 10px;
        font-weight: 700;
    }

    /* ── TOKEN REFERENCE TABLE ── */
    .doc-token-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13px;
    }

    .doc-token-table th {
        padding: 10px 14px;
        text-align: left;
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-muted);
        border-bottom: 1px solid
            color-mix(in srgb, var(--color-neutral-600) 22%, transparent);
    }

    .doc-token-table td {
        padding: 10px 14px;
        border-bottom: 1px solid
            color-mix(in srgb, var(--color-neutral-600) 14%, transparent);
    }

    .doc-token-table tr:last-child td {
        border-bottom: none;
    }

    .doc-token-table tr:hover td {
        background: color-mix(in srgb, var(--color-primary) 4%, transparent);
    }

    .doc-token-table .tok {
        font-family: 'Roboto Mono', monospace;
        font-size: 12px;
        color: var(--color-primary);
    }

    .doc-token-table .val {
        font-family: 'Roboto Mono', monospace;
        font-size: 12px;
        color: var(--color-muted);
    }

    .doc-token-table-wrap {
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid
            color-mix(in srgb, var(--color-neutral-600) 22%, transparent);
    }

    /* ── STEP ── */
    .doc-steps {
        display: flex;
        flex-direction: column;
        gap: 0;
    }

    .doc-step {
        display: flex;
        gap: 0;
    }

    .doc-step-left {
        display: flex;
        flex-direction: column;
        align-items: center;
        width: 48px;
        flex-shrink: 0;
    }

    .doc-step-num {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: color-mix(in srgb, var(--color-primary) 15%, transparent);
        border: 1.5px solid var(--color-primary);
        color: var(--color-primary);
        font-weight: 800;
        font-size: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1;
    }

    .doc-step-line {
        flex: 1;
        width: 1.5px;
        background: color-mix(in srgb, var(--color-primary) 18%, transparent);
        margin: 5px 0;
    }

    .doc-step:last-child .doc-step-line {
        display: none;
    }

    .doc-step-body {
        padding: 2px 0 36px 20px;
        flex: 1;
        min-width: 0;
    }

    .doc-step-title {
        font-size: 15px;
        font-weight: 700;
        margin-bottom: 6px;
    }

    .doc-step-desc {
        font-size: 13px;
        color: var(--color-muted);
        line-height: 1.65;
    }

    /* ── GOOD / BAD ── */
    .doc-compare {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
    }

    .doc-compare-label {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
    }

    /* ── SPACING VISUAL ── */
    .doc-space-row {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        align-items: flex-end;
    }

    .doc-space-block {
        text-align: center;
    }

    .doc-space-sq {
        background: var(--color-primary);
        border-radius: 3px;
        margin: 0 auto 6px;
    }

    .doc-space-label {
        font-size: 10px;
        font-family: 'Roboto Mono', monospace;
        color: var(--color-muted);
        line-height: 1.5;
    }

    /* ── FONT SCALE VISUAL ── */
    .doc-font-row {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        align-items: baseline;
        padding: 20px;
        background: var(--color-dark-secondary);
        border-radius: 12px;
        border: 1px solid
            color-mix(in srgb, var(--color-neutral-600) 22%, transparent);
    }

    .doc-font-item {
        text-align: center;
    }

    .doc-font-label {
        font-size: 10px;
        font-family: 'Roboto Mono', monospace;
        color: var(--color-muted);
        margin-top: 6px;
        line-height: 1.5;
    }

    /* ── FONT FAMILIES ── */
    .doc-font-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 10px;
    }
    .doc-font-card {
        padding: 14px 16px;
        background: var(--color-dark-secondary);
        border: 1px solid
            color-mix(in srgb, var(--color-neutral-600) 22%, transparent);
        border-radius: 12px;
        transition: border-color 0.2s;
    }
    .doc-font-card:hover {
        border-color: color-mix(in srgb, var(--color-primary) 35%, transparent);
    }
    .doc-font-preview {
        font-size: 15px;
        font-weight: 500;
        color: var(--color-light);
        margin-bottom: 10px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .doc-font-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 6px;
    }
    .doc-font-meta code {
        font-size: 10px;
        color: var(--color-primary);
        background: color-mix(in srgb, var(--color-primary) 10%, transparent);
        padding: 2px 6px;
        border-radius: 4px;
    }
    .doc-font-meta span {
        font-size: 10px;
        color: var(--color-muted);
    }
    .doc-font-role-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 5px 10px;
        background: var(--color-dark-secondary);
        border: 1px solid
            color-mix(in srgb, var(--color-neutral-600) 25%, transparent);
        border-radius: 8px;
        font-size: 12px;
    }
    .doc-font-role-label {
        font-family: 'Roboto Mono', monospace;
        color: var(--color-primary);
        font-size: 11px;
    }
    .doc-font-role-val {
        color: var(--color-muted);
    }

    /* ── RADIUS VISUAL ── */
    .doc-radius-row {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
        align-items: center;
    }

    .doc-radius-block {
        text-align: center;
    }

    .doc-radius-sq {
        width: 40px;
        height: 40px;
        background: var(--color-primary);
        margin: 0 auto 6px;
    }

    .doc-radius-label {
        font-size: 9px;
        font-family: 'Roboto Mono', monospace;
        color: var(--color-muted);
        line-height: 1.5;
    }

    /* ── SHADOW VISUAL ── */
    .doc-shadow-list {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .doc-shadow-item {
        height: 34px;
        background: var(--color-dark-secondary);
        border-radius: 8px;
        display: flex;
        align-items: center;
        padding: 0 14px;
        font-size: 12px;
        font-family: 'Roboto Mono', monospace;
    }

    /* ── TIP BOX ── */
    .doc-tip {
        display: flex;
        gap: 14px;
        align-items: flex-start;
        padding: 16px 20px;
        border-radius: 12px;
        background: color-mix(in srgb, var(--color-primary) 8%, transparent);
        border: 1px solid
            color-mix(in srgb, var(--color-primary) 22%, transparent);
        margin-top: 16px;
    }

    .doc-tip-icon {
        font-size: 18px;
        flex-shrink: 0;
        line-height: 1.4;
    }

    .doc-tip-text {
        font-size: 13px;
        color: var(--color-muted);
        line-height: 1.65;
    }

    .doc-tip-text strong {
        color: var(--color-light);
    }

    /* ── FILE TREE ── */
    .doc-tree {
        font-family: 'Roboto Mono', monospace;
        font-size: 12px;
        line-height: 2;
        color: var(--color-muted);
        padding: 20px 24px;
        background: #0d0d0d;
        border-radius: 14px;
        border: 1px solid #222;
        overflow-x: auto;
        white-space: pre;
        margin: 0;
    }

    .doc-tree .dir {
        color: var(--color-primary);
        font-weight: 700;
    }

    .doc-tree .file-main {
        color: var(--color-light);
        font-weight: 600;
    }

    .doc-tree .file {
        color: #c9d1d9;
    }

    .doc-tree .comment {
        color: #555;
        font-style: italic;
    }

    /* ── UTIL TAGS ── */
    .doc-util-tag {
        display: inline-block;
        padding: 3px 8px;
        border-radius: 6px;
        font-family: 'Roboto Mono', monospace;
        font-size: 11px;
        background: color-mix(in srgb, var(--color-primary) 10%, transparent);
        color: var(--color-primary);
        border: 1px solid
            color-mix(in srgb, var(--color-primary) 22%, transparent);
        margin: 3px 3px 3px 0;
    }

    /* ── FLAVOR CARDS ── */
    .doc-flavor-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin: 28px 0 36px;
    }
    .doc-flavor-card {
        padding: 20px;
        border-radius: 14px;
        border: 1.5px solid
            color-mix(in srgb, var(--color-neutral-600) 28%, transparent);
        background: var(--color-dark-secondary);
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
        overflow: hidden;
    }
    .doc-flavor-card::before {
        content: '';
        position: absolute;
        inset: 0;
        opacity: 0;
        background: radial-gradient(
