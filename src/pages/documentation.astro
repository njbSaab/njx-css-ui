---
import BaseLayout from '../layouts/BaseLayout.astro';
import PagesTopbar from '../components/PagesTopbar.astro';
import LibsFooter from '../components/LibsFooter.astro';
import Sidebar from '../components/Sidebar.astro';
import DocSidebar from '../components/DocSidebar.astro';
import Bottombar from '../components/Bottombar.astro';
import { LIB_VERSION, SIZE_FULL, SIZE_CLASSLESS } from '../lib/meta';
const base = import.meta.env.BASE_URL;
---

<BaseLayout
    title="Documentation — njX UI · Components, Tokens, JavaScript Reference"
    description="Full reference for njX UI: design tokens, component classes, JavaScript helpers, themes and classless mode. Everything in one place."
    withDocsCss={true}
    withDocsScripts={true}
>
    <!-- ── OG / Twitter meta → head slot ── -->
    <meta slot="head" property="og:type" content="website" />
    <meta
        slot="head"
        property="og:title"
        content="njX UI Documentation — Full Reference"
    />
    <meta
        slot="head"
        property="og:description"
        content="Design tokens, component classes, JavaScript helpers and themes — full njX UI reference."
    />
    <meta
        slot="head"
        property="og:image"
        content="https://njxui.dev/img/og-image.png"
    />
    <meta
        slot="head"
        property="og:url"
        content="https://njxui.dev/documentation"
    />
    <meta slot="head" name="twitter:card" content="summary_large_image" />
    <meta
        slot="head"
        name="twitter:title"
        content="njX UI Documentation — Full Reference"
    />
    <meta
        slot="head"
        name="twitter:description"
        content="Design tokens, component classes, JavaScript helpers and themes — full njX UI reference."
    />
    <meta
        slot="head"
        name="twitter:image"
        content="https://njxui.dev/img/og-image.png"
    />

    <!-- ══════════════════════ NAV ══════════════════════ -->
    <PagesTopbar activePage="documentation" />

    <div class="lib-wrap">
        <Sidebar><DocSidebar /></Sidebar>
        <!-- ══════════════════════ HERO ══════════════════════ -->
        <main class="doc-main lib-main">
            <!-- ══════════ STICKY MODE BAR ══════════ -->
            <div class="doc-mode-bar" id="doc-mode-bar">
                <span class="doc-mode-label">Mode</span>
                <div class="doc-mode-tabs">
                    <button
                        class="doc-mode-tab active"
                        data-mode="full"
                        onclick="pageSyncFlavor('full')"
                    >
                        <span class="doc-mode-icon">◈</span>
                        Full
                        <span class="doc-mode-default">RECOMMENDED</span>
                        <span class="doc-mode-size">{SIZE_FULL}</span>
                    </button>
                    <button
                        class="doc-mode-tab"
                        data-mode="classless"
                        onclick="pageSyncFlavor('classless')"
                    >
                        <span class="doc-mode-icon">&lt;/&gt;</span>
                        Classless Only
                        <span class="doc-mode-default">LITE</span>
                        <span class="doc-mode-size">{SIZE_CLASSLESS}</span>
                    </button>
                    <button
                        class="doc-mode-tab"
                        data-mode="interactive"
                        onclick="pageSyncFlavor('interactive')"
                    >
                        <span class="doc-mode-icon">JS</span>
                        Interactive
                    </button>
                </div>
                <span class="doc-mode-hint" id="doc-mode-hint">
                    Classless built-in — your HTML is styled automatically
                </span>
            </div>

            <!-- ══════════ QUICK START ══════════ -->
            <section class="doc-section" id="quickstart">
                <!-- ── Flavor-aware section header ── -->
                <div class="doc-section-header" data-flavor-code="full">
                    <span class="sc-eyebrow">Getting started</span>
                    <h1 class="sc-heading">Quick Start</h1>
                    <p class="sc-subheading">
                        Connect the library to your project in under a minute —
                        no build tools required.
                    </p>
                </div>
                <div
                    class="doc-section-header"
                    data-flavor-code="classless"
                    style="display:none"
                >
                    <span class="sc-eyebrow">Getting started</span>
                    <h1 class="sc-heading">Quick Start — Classless Only</h1>
                    <p class="sc-subheading">
                        Standalone mode — one file, zero class names. Semantic
                        HTML is styled automatically via element selectors. Use <code
                            style="color:var(--color-primary)"
                            >classless.min.css</code
                        >
                        when you need classless without any component classes. Want
                        components too? Add <code>classless-mode.css</code> alongside
                        <strong>Full</strong> and set <code
                            >html[data-classless]</code
                        >.
                    </p>
                </div>
                <div
                    class="doc-section-header"
                    data-flavor-code="interactive"
                    style="display:none"
                >
                    <span class="sc-eyebrow">Getting started</span>
                    <h1 class="sc-heading">Quick Start — Interactive</h1>
                    <p class="sc-subheading">
                        Full CSS components plus JavaScript-powered interactions
                        out of the box — modals, tabs, toasts, dropdowns.
                    </p>
                </div>

                <!-- ── Version selector cards ── -->
                <div class="doc-flavor-cards">
                    <div
                        class="doc-flavor-card"
                        data-flavor-card="classless"
                        onclick="pageSyncFlavor('classless')"
                    >
                        <div class="doc-flavor-card-icon" style="color:#4ade80">
                            &lt;/&gt;
                        </div>
                        <div class="doc-flavor-card-title">Classless Only</div>
                        <div class="doc-flavor-card-desc">
                            Standalone — no component classes. Semantic HTML
                            gets styled automatically. Zero dependencies.
                        </div>
                        <div class="doc-flavor-card-badge">
                            classless.min.css · 47 KB
                        </div>
                    </div>
                    <div
                        class="doc-flavor-card active"
                        data-flavor-card="full"
                        onclick="pageSyncFlavor('full')"
                    >
                        <div class="doc-flavor-card-label-default">
                            RECOMMENDED
                        </div>
                        <div
                            class="doc-flavor-card-icon"
                            style="color:var(--color-primary)"
                        >
                            ◈
                        </div>
                        <div class="doc-flavor-card-title">Full</div>
                        <div class="doc-flavor-card-desc">
                            30+ component classes — <code>.btn</code>, <code
                                >.card</code
                            >,
                            <code>.tag</code> and more. Add <code
                                >classless-mode.css</code
                            >
                            to also style bare elements.
                        </div>
                        <div class="doc-flavor-card-badge">
                            style.min.css · 308 KB
                        </div>
                    </div>
                    <div
                        class="doc-flavor-card"
                        data-flavor-card="interactive"
                        onclick="pageSyncFlavor('interactive')"
                    >
                        <div class="doc-flavor-card-icon" style="color:#facc15">
                            JS
                        </div>
                        <div class="doc-flavor-card-title">Interactive</div>
                        <div class="doc-flavor-card-desc">
                            Everything in Full plus JS-powered modals, tabs,
                            toasts, dropdowns and more.
                        </div>
                        <div class="doc-flavor-card-badge">
                            style.min.css + njx.js
                        </div>
                    </div>
                </div>

                <!-- ── Full mode tip ── -->
                <div class="doc-mix-tip">
                    <span class="doc-mix-tip-icon">✦</span>
                    <span>
                        <strong>Mixed mode available.</strong>
                        Load <code>style.min.css</code> + <code
                            >classless-mode.css</code
                        >
                        and add <code>data-classless</code> to <code
                            >&lt;html&gt;</code
                        >
                        — bare elements get styled AND component classes stay available.
                        Zero cascade conflicts.
                    </span>
                </div>

                <!-- ── Steps: Full ── -->
                <div class="doc-steps" data-flavor-code="full">
                    <div class="doc-step">
                        <div class="doc-step-left">
                            <div class="doc-step-num">1</div>
                            <div class="doc-step-line"></div>
                        </div>
                        <div class="doc-step-body">
                            <div class="doc-step-title">Add the stylesheet</div>
                            <div class="doc-step-desc">
                                One <code>&lt;link&gt;</code> tag in <code
                                    >&lt;head&gt;</code
                                >. Nothing else required.
                            </div>
                            <div class="sc-code-wrap">
                                <div class="sc-code-body">
                                    <span class="k">&lt;link</span>
                                    <span class="t">rel</span>=<span class="s"
                                        >"stylesheet"</span
                                    >
                                    <span class="t">href</span>=<span class="s"
                                        >"https://cdn.jsdelivr.net/npm/njx-ui/css/style.min.css"</span
                                    ><span class="k">&gt;</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="doc-step">
                        <div class="doc-step-left">
                            <div class="doc-step-num">2</div>
                            <div class="doc-step-line"></div>
                        </div>
                        <div class="doc-step-body">
                            <div class="doc-step-title">Set a theme</div>
                            <div class="doc-step-desc">
                                Add <code>data-theme</code> to the <code
                                    >&lt;html&gt;</code
                                > element. All components adapt automatically.
                            </div>
                            <div class="sc-code-wrap">
                                <div class="sc-code-body">
                                    <span class="k">&lt;html</span>
                                    <span class="t">lang</span>=<span class="s"
                                        >"en"</span
                                    >
                                    <span class="t">data-theme</span>=<span
                                        class="s">"dark"</span
                                    ><span class="k">&gt;</span>
                                    <span class="c"
                                        >&lt;!-- dark · light · red · blue ·
                                        green · cyan · yellow · pink · purple
                                        --&gt;</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="doc-step">
                        <div class="doc-step-left">
                            <div class="doc-step-num">3</div>
                            <div class="doc-step-line"></div>
                        </div>
                        <div class="doc-step-body">
                            <div class="doc-step-title">
                                Use component classes
                            </div>
                            <div class="doc-step-desc">
                                Add class names to HTML elements. Most
                                components are pure CSS — no JavaScript needed.
                            </div>
                            <div class="sc-code-wrap">
                                <div class="sc-code-header">
                                    <div class="sc-code-dots">
                                        <div
                                            class="sc-code-dot"
                                            style="background:#ff5f57"
                                        >
                                        </div>
                                        <div
                                            class="sc-code-dot"
                                            style="background:#febc2e"
                                        >
                                        </div>
                                        <div
                                            class="sc-code-dot"
                                            style="background:#28c840"
                                        >
                                        </div>
                                    </div>
                                    <span class="sc-code-filename"
                                        >index.html</span
                                    >
                                    <button
                                        class="sc-code-copy"
                                        onclick="copyBlock('qs-code-full',this)"
                                        >Copy</button
                                    >
                                </div>
                                <div class="sc-code-body" id="qs-code-full">
                                    <span class="k">&lt;!DOCTYPE html&gt;</span>
                                    <span class="k">&lt;html</span>
                                    <span class="t">lang</span>=<span class="s"
                                        >"en"</span
                                    >
                                    <span class="t">data-theme</span>=<span
                                        class="s">"dark"</span
                                    ><span class="k">&gt;</span>
                                    <span class="k">&lt;head&gt;</span>
                                    &nbsp;&nbsp;<span class="k">&lt;meta</span>
                                    <span class="t">charset</span>=<span
                                        class="s">"UTF-8"</span
                                    ><span class="k">&gt;</span>
                                    &nbsp;&nbsp;<span class="k">&lt;link</span>
                                    <span class="t">rel</span>=<span class="s"
                                        >"stylesheet"</span
                                    >
                                    <span class="t">href</span>=<span class="s"
                                        >"https://cdn.jsdelivr.net/npm/njx-ui/css/style.min.css"</span
                                    ><span class="k">&gt;</span>
                                    <span class="k">&lt;/head&gt;</span>
                                    <span class="k">&lt;body&gt;</span>
                                    &nbsp;&nbsp;<span class="k">&lt;button</span
                                    >
                                    <span class="t">class</span>=<span class="s"
                                        >"btn btn-primary"</span
                                    ><span class="k">&gt;</span>Hello njX<span
                                        class="k">&lt;/button&gt;</span
                                    >
                                    &nbsp;&nbsp;<span class="k">&lt;div</span>
                                    <span class="t">class</span>=<span class="s"
                                        >"card-glow"</span
                                    ><span class="k">&gt;</span>
                                    &nbsp;&nbsp;&nbsp;&nbsp;<span class="k"
                                        >&lt;h2</span
                                    >
                                    <span class="t">class</span>=<span class="s"
                                        >"text-gradient-primary"</span
                                    ><span class="k">&gt;</span>Works.<span
                                        class="k">&lt;/h2&gt;</span
                                    >
                                    &nbsp;&nbsp;<span class="k"
                                        >&lt;/div&gt;</span
                                    >
                                    <span class="k">&lt;/body&gt;</span>
                                    <span class="k">&lt;/html&gt;</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Step 4: JS (Full only) -->
                <div
                    class="doc-step"
                    style="margin-top:0"
                    data-flavor-code="full"
                >
                    <div class="doc-step-left">
                        <div class="doc-step-num">4</div>
                    </div>
                    <div class="doc-step-body">
                        <div class="doc-step-title">
                            Add JavaScript <span
                                style="font-size:12px;font-weight:400;color:var(--color-muted)"
                                >(optional)</span
                            >
                        </div>
                        <div class="doc-step-desc">
                            Interactive components — collapse, tabs, dropdown,
                            modal, carousel, toast — need one script.
                        </div>
                        <div class="sc-code-wrap" style="margin-top:12px">
                            <div class="sc-code-body">
                                <span class="c"
                                    >&lt;!-- Adds: collapseToggle, tabSwitch,
                                    dropdownToggle,</span
                                >
                                <span class="c"
                                    >&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;openModal,
                                    closeModal, showToast, initCarousels --&gt;</span
                                >
                                <span class="k">&lt;script</span>
                                <span class="t">src</span>=<span class="s"
                                    >"https://cdn.jsdelivr.net/npm/njx-ui/js/njx.js"</span
                                ><span class="k">&gt;&lt;/script&gt;</span>
                            </div>
                        </div>
                        <div
                            style="margin-top:10px;font-size:13px;color:var(--color-muted)"
                        >
                            Native <code>details/summary</code> components work without
                            JS. See the <a
                                href="#javascript"
                                style="color:var(--color-primary)"
                                >JavaScript reference</a
                            > for all functions.
                        </div>
                    </div>
                </div>

                <!-- ── Steps: Classless ── -->
                <div
                    class="doc-steps"
                    data-flavor-code="classless"
                    style="display:none"
                >
                    <div class="doc-step">
                        <div class="doc-step-left">
                            <div class="doc-step-num">1</div>
                            <div class="doc-step-line"></div>
                        </div>
                        <div class="doc-step-body">
                            <div class="doc-step-title">Add the stylesheet</div>
                            <div class="doc-step-desc">
                                One <code>&lt;link&gt;</code> tag in <code
                                    >&lt;head&gt;</code
                                >. No configuration needed.
                            </div>
                            <div class="sc-code-wrap">
                                <div class="sc-code-body">
                                    <span class="k">&lt;link</span>
                                    <span class="t">rel</span>=<span class="s"
                                        >"stylesheet"</span
                                    >
                                    <span class="t">href</span>=<span class="s"
                                        >"https://cdn.jsdelivr.net/npm/njx-ui/css/classless.min.css"</span
                                    ><span class="k">&gt;</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="doc-step">
                        <div class="doc-step-left">
                            <div class="doc-step-num">2</div>
                            <div class="doc-step-line"></div>
                        </div>
                        <div class="doc-step-body">
                            <div class="doc-step-title">Write plain HTML</div>
                            <div class="doc-step-desc">
                                No class names needed. Every native HTML element
                                — <code>&lt;button&gt;</code>, <code
                                    >&lt;table&gt;</code
                                >, <code>&lt;form&gt;</code>, <code
                                    >&lt;details&gt;</code
                                > — gets styled automatically.
                            </div>
                            <div class="sc-code-wrap">
                                <div class="sc-code-header">
                                    <div class="sc-code-dots">
                                        <div
                                            class="sc-code-dot"
                                            style="background:#ff5f57"
                                        >
                                        </div>
                                        <div
                                            class="sc-code-dot"
                                            style="background:#febc2e"
                                        >
                                        </div>
                                        <div
                                            class="sc-code-dot"
                                            style="background:#28c840"
                                        >
                                        </div>
                                    </div>
                                    <span class="sc-code-filename"
                                        >index.html</span
                                    >
                                    <button
                                        class="sc-code-copy"
                                        onclick="copyBlock('qs-code-classless',this)"
                                        >Copy</button
                                    >
                                </div>
                                <div
                                    class="sc-code-body"
                                    id="qs-code-classless"
                                >
                                    <span class="k">&lt;!DOCTYPE html&gt;</span>
                                    <span class="k">&lt;html</span>
                                    <span class="t">lang</span>=<span class="s"
                                        >"en"</span
                                    ><span class="k">&gt;</span>
                                    <span class="k">&lt;head&gt;</span>
                                    &nbsp;&nbsp;<span class="k">&lt;meta</span>
                                    <span class="t">charset</span>=<span
                                        class="s">"UTF-8"</span
                                    ><span class="k">&gt;</span>
                                    &nbsp;&nbsp;<span class="k">&lt;link</span>
                                    <span class="t">rel</span>=<span class="s"
                                        >"stylesheet"</span
                                    >
                                    <span class="t">href</span>=<span class="s"
                                        >"https://cdn.jsdelivr.net/npm/njx-ui/css/classless.min.css"</span
                                    ><span class="k">&gt;</span>
                                    <span class="k">&lt;/head&gt;</span>
                                    <span class="k">&lt;body&gt;</span>
                                    &nbsp;&nbsp;<span class="k"
                                        >&lt;button&gt;</span
                                    >Hello njX<span class="k"
                                        >&lt;/button&gt;</span
                                    >
                                    &nbsp;&nbsp;<span class="k"
                                        >&lt;article&gt;</span
                                    >
                                    &nbsp;&nbsp;&nbsp;&nbsp;<span class="k"
                                        >&lt;h2&gt;</span
                                    >Works.<span class="k">&lt;/h2&gt;</span>
                                    &nbsp;&nbsp;&nbsp;&nbsp;<span class="k"
                                        >&lt;p&gt;</span
                                    >No class names needed.<span class="k"
                                        >&lt;/p&gt;</span
                                    >
                                    &nbsp;&nbsp;<span class="k"
                                        >&lt;/article&gt;</span
                                    >
                                    <span class="k">&lt;/body&gt;</span>
                                    <span class="k">&lt;/html&gt;</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="doc-step">
                        <div class="doc-step-left">
                            <div class="doc-step-num">3</div>
                        </div>
                        <div class="doc-step-body">
                            <div class="doc-step-title">
                                Themes <span
                                    style="font-size:12px;font-weight:400;color:var(--color-muted)"
                                    >(optional)</span
                                >
                            </div>
                            <div class="doc-step-desc">
                                Classless supports the same 9 themes. Add <code
                                    >data-theme</code
                                > to <code>&lt;html&gt;</code> to switch color palettes.
                            </div>
                            <div class="sc-code-wrap">
                                <div class="sc-code-body">
                                    <span class="k">&lt;html</span>
                                    <span class="t">data-theme</span>=<span
                                        class="s">"dark"</span
                                    ><span class="k">&gt;</span>
                                    <span class="c"
                                        >&lt;!-- dark · light · red · blue ·
                                        green · cyan · yellow · pink · purple
                                        --&gt;</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- ── Steps: Interactive ── -->
                <div
                    class="doc-steps"
                    data-flavor-code="interactive"
                    style="display:none"
                >
                    <div class="doc-step">
                        <div class="doc-step-left">
                            <div class="doc-step-num">1</div>
                            <div class="doc-step-line"></div>
                        </div>
                        <div class="doc-step-body">
                            <div class="doc-step-title">Add CSS + JS</div>
                            <div class="doc-step-desc">
                                Two tags in <code>&lt;head&gt;</code> and before <code
                                    >&lt;/body&gt;</code
                                >. JS unlocks modals, tabs, toasts, dropdowns.
                            </div>
                            <div class="sc-code-wrap">
                                <div class="sc-code-body">
                                    <span class="c"
                                        >&lt;!-- In &lt;head&gt; --&gt;</span
                                    >
                                    <span class="k">&lt;link</span>
                                    <span class="t">rel</span>=<span class="s"
                                        >"stylesheet"</span
                                    >
                                    <span class="t">href</span>=<span class="s"
                                        >"https://cdn.jsdelivr.net/npm/njx-ui/css/style.min.css"</span
                                    ><span class="k">&gt;</span>

                                    <span class="c"
                                        >&lt;!-- Before &lt;/body&gt; --&gt;</span
                                    >
                                    <span class="k">&lt;script</span>
                                    <span class="t">src</span>=<span class="s"
                                        >"https://cdn.jsdelivr.net/npm/njx-ui/js/njx.js"</span
                                    ><span class="k">&gt;&lt;/script&gt;</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="doc-step">
                        <div class="doc-step-left">
                            <div class="doc-step-num">2</div>
                            <div class="doc-step-line"></div>
                        </div>
                        <div class="doc-step-body">
                            <div class="doc-step-title">Set a theme</div>
                            <div class="doc-step-desc">
                                Add <code>data-theme</code> to <code
                                    >&lt;html&gt;</code
                                >. All components adapt automatically.
                            </div>
                            <div class="sc-code-wrap">
                                <div class="sc-code-body">
                                    <span class="k">&lt;html</span>
                                    <span class="t">lang</span>=<span class="s"
                                        >"en"</span
                                    >
                                    <span class="t">data-theme</span>=<span
                                        class="s">"dark"</span
                                    ><span class="k">&gt;</span>
                                    <span class="c"
                                        >&lt;!-- dark · light · red · blue ·
                                        green · cyan · yellow · pink · purple
                                        --&gt;</span
                                    >
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="doc-step">
                        <div class="doc-step-left">
                            <div class="doc-step-num">3</div>
                        </div>
                        <div class="doc-step-body">
                            <div class="doc-step-title">
                                Use components + JS API
                            </div>
                            <div class="doc-step-desc">
                                Classes work the same as Full. JS functions are
                                available globally — no import needed.
                            </div>
                            <div class="sc-code-wrap">
                                <div class="sc-code-header">
                                    <div class="sc-code-dots">
                                        <div
                                            class="sc-code-dot"
                                            style="background:#ff5f57"
                                        >
                                        </div>
                                        <div
                                            class="sc-code-dot"
                                            style="background:#febc2e"
                                        >
                                        </div>
                                        <div
                                            class="sc-code-dot"
                                            style="background:#28c840"
                                        >
                                        </div>
                                    </div>
                                    <span class="sc-code-filename"
                                        >index.html</span
                                    >
                                    <button
                                        class="sc-code-copy"
                                        onclick="copyBlock('qs-code-interactive',this)"
                                        >Copy</button
                                    >
                                </div>
                                <div
