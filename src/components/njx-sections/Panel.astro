                    &nbsp;&nbsp;<span class="k">&lt;a&gt;</span>Public<span
                        class="k">&lt;/a&gt;</span
                    ><br />
                    <span class="k">&lt;/div&gt;</span>
                </div>
                <button class="lib-copy-btn" onclick="copyCode(this)"
                    >Copy</button
                >
            </div>
        </div>
    </div>

    <!-- ── 3. With Search ── -->
    <div class="lib-component">
        <div class="lib-component-label">With search filter</div>
        <div class="lib-preview">
            <div class="panel" style="min-width:280px">
                <div class="panel-heading">Team members</div>
                <div class="panel-search">
                    <input type="text" placeholder="Search member…" />
                </div>
                <a class="panel-block is-active">
                    <span class="panel-icon">👤</span> Alice Johnson
                    <span class="panel-block-badge">Admin</span>
                </a>
                <a class="panel-block">
                    <span class="panel-icon">👤</span> Bob Smith
                    <span class="panel-block-badge is-muted">Member</span>
                </a>
                <a class="panel-block">
                    <span class="panel-icon">👤</span> Carol White
                    <span class="panel-block-badge is-muted">Member</span>
                </a>
                <div class="panel-footer">
                    <button class="btn btn-primary btn-sm">Invite</button>
                </div>
            </div>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
                    class="lib-code"
                    data-raw='<div class="panel">
  <div class="panel-heading">Team members</div>
  <div class="panel-search">
    <input type="text" placeholder="Search…">
  </div>
  <a class="panel-block">
    Alice <span class="panel-block-badge">Admin</span>
  </a>
  <div class="panel-footer">...</div>
</div>'
                >
                    <span class="c">&lt;!-- search input --&gt;</span><br />
                    <span class="k">&lt;div</span>
                    <span class="s">class</span>=<span class="cn"
                        >"panel-search"</span
                    ><span class="k">&gt;</span><br />
                    &nbsp;&nbsp;<span class="k">&lt;input</span>
                    <span class="s">type</span>=<span class="cn">"text"</span>
                    <span class="s">placeholder</span>=<span class="cn"
                        >"Search…"</span
                    ><span class="k">&gt;</span><br />
                    <span class="k">&lt;/div&gt;</span><br />
                    <span class="c">&lt;!-- badge --&gt;</span><br />
                    <span class="k">&lt;span</span>
                    <span class="s">class</span>=<span class="cn"
                        >"panel-block-badge"</span
                    ><span class="k">&gt;</span>Admin<span class="k"
                        >&lt;/span&gt;</span
                    ><br />
                    <span class="c">&lt;!-- footer --&gt;</span><br />
                    <span class="k">&lt;div</span>
                    <span class="s">class</span>=<span class="cn"
                        >"panel-footer"</span
                    ><span class="k">&gt;</span>...<span class="k"
                        >&lt;/div&gt;</span
