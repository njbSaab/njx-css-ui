        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
                    class="lib-code"
                    data-raw='<div class="panel is-primary">
  <div class="panel-heading">Repository</div>
  <div class="panel-tabs">
    <a class="is-active">All</a>
    <a>Public</a>
  </div>
  <a class="panel-block is-active">item</a>
</div>'
                >
                    <span class="k">&lt;div</span>
                    <span class="s">class</span>=<span class="cn"
                        >"panel-tabs"</span
                    ><span class="k">&gt;</span><br />
                    &nbsp;&nbsp;<span class="k">&lt;a</span>
                    <span class="s">class</span>=<span class="cn"
