<section class="lib-section" id="panel">
    <div class="lib-section-title">🗃 Panel</div>
    <div class="lib-section-desc">
        List panel component — filterable, selectable, with tabs, badges and
        actions. From <code>_breadcrumb.css</code>. Color variants: <code
            >is-primary</code
        >
        <code>is-success</code>
        <code>is-warning</code>
        <code>is-danger</code>.
    </div>

    <!-- ── 1. Color variants ── -->
    <div class="lib-component">
        <div class="lib-component-label">Color variants</div>
        <div
            class="lib-preview"
            style="align-items:flex-start;flex-wrap:wrap;gap:16px"
        >
            <div class="panel is-primary" style="min-width:200px">
                <div class="panel-heading">Primary</div>
                <a class="panel-block is-active"
                    ><span class="panel-icon">⭐</span> Dashboard</a
                >
                <a class="panel-block"
                    ><span class="panel-icon">📁</span> Projects</a
                >
                <a class="panel-block"
                    ><span class="panel-icon">⚙️</span> Settings</a
                >
            </div>
            <div class="panel is-success" style="min-width:200px">
                <div class="panel-heading">Success</div>
                <a class="panel-block is-active"
                    ><span class="panel-icon">✅</span> Deployed</a
                >
                <a class="panel-block"
                    ><span class="panel-icon">📦</span> Packages</a
                >
                <a class="panel-block"
                    ><span class="panel-icon">🔗</span> Links</a
                >
            </div>
            <div class="panel is-warning" style="min-width:200px">
                <div class="panel-heading">Warning</div>
                <a class="panel-block is-active"
                    ><span class="panel-icon">⚠️</span> Pending</a
                >
                <a class="panel-block"
                    ><span class="panel-icon">🕐</span> Queued</a
                >
                <a class="panel-block"
                    ><span class="panel-icon">🔄</span> In Progress</a
                >
            </div>
            <div class="panel is-danger" style="min-width:200px">
                <div class="panel-heading">Danger</div>
                <a class="panel-block is-active"
                    ><span class="panel-icon">❌</span> Errors</a
                >
                <a class="panel-block"
                    ><span class="panel-icon">🚫</span> Blocked</a
                >
                <a class="panel-block"
                    ><span class="panel-icon">🗑️</span> Deleted</a
                >
            </div>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
                    class="lib-code"
                    data-raw='<div class="panel is-primary">
  <div class="panel-heading">Title</div>
  <a class="panel-block is-active"><span class="panel-icon">⭐</span> Item</a>
  <a class="panel-block"><span class="panel-icon">📁</span> Item 2</a>
</div>'
                >
                    <span class="k">&lt;div</span>
                    <span class="s">class</span>=<span class="cn"
                        >"panel is-primary"</span
                    ><span class="k">&gt;</span><br />
                    &nbsp;&nbsp;<span class="k">&lt;div</span>
                    <span class="s">class</span>=<span class="cn"
                        >"panel-heading"</span
                    ><span class="k">&gt;</span>Title<span class="k"
                        >&lt;/div&gt;</span
                    ><br />
                    &nbsp;&nbsp;<span class="k">&lt;a</span>
                    <span class="s">class</span>=<span class="cn"
                        >"panel-block is-active"</span
                    ><span class="k">&gt;</span>...<span class="k"
                        >&lt;/a&gt;</span
                    ><br />
                    <span class="k">&lt;/div&gt;</span>
                </div>
                <button class="lib-copy-btn" onclick="copyCode(this)"
                    >Copy</button
                >
            </div>
        </div>
    </div>

    <!-- ── 2. With Tabs ── -->
