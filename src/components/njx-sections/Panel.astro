    <!-- ── 4. With Checkboxes ── -->
    <div class="lib-component">
        <div class="lib-component-label">Selectable — checkboxes</div>
        <div class="lib-preview">
            <div class="panel" style="min-width:280px">
                <div class="panel-heading">Features</div>
                <label class="panel-block">
                    <input type="checkbox" checked /> Dark mode
                    <span class="panel-block-meta">enabled</span>
                </label>
                <label class="panel-block">
                    <input type="checkbox" checked /> Animations
                    <span class="panel-block-meta">enabled</span>
                </label>
                <label class="panel-block">
                    <input type="checkbox" /> Compact layout
                    <span class="panel-block-meta">disabled</span>
                </label>
                <label class="panel-block">
                    <input type="checkbox" /> Beta features
                    <span class="panel-block-meta">disabled</span>
                </label>
                <div class="panel-footer">
                    <button class="btn btn-sm btn-outline">Reset</button>
                    <button class="btn btn-sm btn-primary">Save</button>
                </div>
            </div>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
