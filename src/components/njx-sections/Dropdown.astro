  <button class="btn btn-ghost btn-sm"
    onclick="dropdownToggle(this.parentElement)">
    Menu <span class="dropdown-arrow"></span>
  </button>
  <div class="dropdown-menu">
    <a href="#" class="dropdown-item">Item</a>
  </div>
</div>

<script>
function dropdownToggle(el) {
  el.classList.toggle("is-open");
}
// Close on outside click
document.addEventListener("click", e => {
  document.querySelectorAll(".dropdown.is-open").forEach(dd => {
    if (!dd.contains(e.target)) dd.classList.remove("is-open");
  });
});
</script>'
