    <div id="modal-column" class="lib-modal-overlay" onclick="if(event.target===this)closeModal(this)">
        <div class="lib-modal-box is-warning">
            <button class="lib-modal-close" onclick="closeModal(document.getElementById('modal-column'))">✕</button>
            <div class="lib-modal-icon-wrap">🗑️</div>
            <div class="lib-modal-title">Delete this item?</div>
            <div class="lib-modal-text">This action cannot be undone. Choose how to proceed:</div>
            <div class="lib-modal-actions is-column">
                <button class="btn btn-danger btn-sm" onclick="closeModal(document.getElementById('modal-column'))">Delete permanently</button>
                <button class="btn btn-warning btn-sm" onclick="closeModal(document.getElementById('modal-column'))">Archive instead</button>
                <button class="btn btn-ghost btn-sm" onclick="closeModal(document.getElementById('modal-column'))">Cancel</button>
            </div>
        </div>
    </div>

    <div id="modal-form" class="lib-modal-overlay" onclick="if(event.target===this)closeModal(this)">
        <div class="lib-modal-box is-primary">
            <button class="lib-modal-close" onclick="closeModal(document.getElementById('modal-form'))">✕</button>
            <div class="lib-modal-icon-wrap">📝</div>
            <div class="lib-modal-title">Send a message</div>
            <div class="lib-modal-text">Fill in the details below and we'll get back to you.</div>
            <div style="display:flex;flex-direction:column;gap:10px;margin-top:4px">
                <input type="text" class="inp" placeholder="Your name" />
                <textarea class="inp" placeholder="Your message..." style="min-height:80px;resize:vertical"></textarea>
            </div>
            <div class="lib-modal-divider"></div>
            <div class="lib-modal-actions">
                <button class="btn btn-primary btn-sm" onclick="closeModal(document.getElementById('modal-form'))">Send</button>
                <button class="btn btn-ghost btn-sm" onclick="closeModal(document.getElementById('modal-form'))">Cancel</button>
            </div>
        </div>
    </div>

</section>

<script is:inline>
(function() {
    if (typeof window.__njxModalsInit !== 'undefined') return;
    window.__njxModalsInit = true;

    window.openModal = function(id) {
        var el = document.getElementById(id);
        if (!el) return;
        el.classList.add('open');
        document.body.style.overflow = 'hidden';
    };

    window.closeModal = function(el) {
        if (!el) return;
        el.classList.remove('open');
        document.body.style.overflow = '';
    };

    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            document.querySelectorAll('.lib-modal-overlay.open').forEach(function(m) {
                m.classList.remove('open');
            });
            document.body.style.overflow = '';
        }
    });
})();
</script>
