        background: color-mix(in srgb, var(--color-primary) 10%, transparent);
        padding: 2px 5px;
        border-radius: 4px;
        white-space: nowrap;
    }
    .njx-font-info span {
        font-size: 10px;
        color: var(--color-muted, #8a8f99);
    }
    .njx-font-chip {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 4px 10px;
        background: var(--color-dark-secondary, #151515);
        border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
        border-radius: 7px;
        font-size: 12px;
    }
    .njx-font-chip-var {
        font-family: 'Roboto Mono', monospace;
        color: var(--color-primary);
        font-size: 11px;
