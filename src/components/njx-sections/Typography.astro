        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--color-muted, #8a8f99);
        margin-bottom: 8px;
    }

    /* ── Font Families (new grid) ── */
    .tk-fonts-label-row {
        font-size: 11px;
        font-family: var(--font-mono);
        color: var(--color-muted);
        padding: 10px 16px 8px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }
    .tk-fonts-label-mono {
        margin-top: 4px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        padding-top: 14px;
    }
    .tk-font-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 10px;
        padding: 0 10px 4px;
    }
    .tk-font-card {
        background: var(--color-dark-secondary);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: var(--radius-md);
        padding: 16px 16px 12px;
        display: flex;
        flex-direction: column;
        gap: 4px;
        transition: border-color var(--ease-fast);
    }
    .tk-font-card:hover {
        border-color: color-mix(in srgb, var(--color-primary) 40%, transparent);
    }
    .tk-font-card--mono {
        background: rgba(20, 160, 255, 0.04);
        border-color: rgba(20, 160, 255, 0.12);
    }
    .tk-font-big {
        font-size: 22px;
        font-weight: 700;
        color: var(--color-light);
        line-height: 1.1;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .tk-font-abc {
        font-size: 12px;
        color: var(--color-muted);
        margin-top: 2px;
    }
    .tk-font-var {
        margin-top: 8px;
        font-size: 10px;
        color: var(--color-primary);
        font-family: var(--font-mono);
        background: rgba(20, 160, 255, 0.08);
        border: 1px solid rgba(20, 160, 255, 0.15);
        border-radius: 4px;
        padding: 2px 6px;
        display: inline-block;
        width: fit-content;
    }
    .tk-font-roles {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        padding: 12px 0 16px;
        border-top: 1px solid rgba(255, 255, 255, 0.05);
        margin-top: 4px;
    }
    .tk-role-pill {
        display: flex;
        align-items: center;
        gap: 6px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 9999px;
        padding: 5px 12px 5px 10px;
        font-family: var(--font-mono);
        font-size: 11px;
