                    <span class="k">&lt;input</span> <span class="s">type</span>=<span class="cn">"text"</span> <span class="s">data-variant</span>=<span class="cn">"warning"</span><span class="k">&gt;</span>
                </div>
            </div>
        </div>
    </div>

