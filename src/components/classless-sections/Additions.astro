                    <span class="k">&lt;a</span> <span class="s">href</span>=<span class="cn">"#"</span> <span class="s">data-variant</span>=<span class="cn">"success"</span><span class="k">&gt;</span><span class="t">Success</span><span class="k">&lt;/a&gt;</span><br />
                    <span class="k">&lt;a</span> <span class="s">href</span>=<span class="cn">"#"</span> <span class="s">data-variant</span>=<span class="cn">"warning"</span><span class="k">&gt;</span><span class="t">Warning</span><span class="k">&lt;/a&gt;</span><br />
                    <span class="k">&lt;a</span> <span class="s">href</span>=<span class="cn">"#"</span> <span class="s">data-variant</span>=<span class="cn">"error"</span><span class="k">&gt;</span><span class="t">Error</span><span class="k">&lt;/a&gt;</span><br />
