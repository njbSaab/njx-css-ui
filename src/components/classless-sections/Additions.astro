<section class="lib-section cl-section" id="variants">
    <div class="lib-section-title">⚡ Variants</div>
    <div class="lib-section-desc">
        <code>data-variant</code> attribute from <code>_native.css</code> — applies semantic color to native elements without class names.
    </div>

    <div class="lib-component">
        <div class="lib-component-label">Button variants</div>
        <div class="lib-preview">
            <article>
                <button>Default</button>
                <button data-variant="accent">Accent</button>
                <button data-variant="success">Success</button>
                <button data-variant="warning">Warning</button>
                <button data-variant="error">Error</button>
                <button data-variant="dark">Dark</button>
                <button data-variant="light">Light</button>
            </article>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div class="lib-code" data-raw='<button>Default</button>
<button data-variant="accent">Accent</button>
<button data-variant="success">Success</button>
<button data-variant="warning">Warning</button>
<button data-variant="error">Error</button>
<button data-variant="dark">Dark</button>
<button data-variant="light">Light</button>'>
                    <span class="k">&lt;button&gt;</span><span class="t">Default</span><span class="k">&lt;/button&gt;</span><br />
                    <span class="k">&lt;button</span> <span class="s">data-variant</span>=<span class="cn">"accent"</span><span class="k">&gt;</span><span class="t">Accent</span><span class="k">&lt;/button&gt;</span><br />
                    <span class="k">&lt;button</span> <span class="s">data-variant</span>=<span class="cn">"success"</span><span class="k">&gt;</span><span class="t">Success</span><span class="k">&lt;/button&gt;</span><br />
                    <span class="k">&lt;button</span> <span class="s">data-variant</span>=<span class="cn">"warning"</span><span class="k">&gt;</span><span class="t">Warning</span><span class="k">&lt;/button&gt;</span><br />
                    <span class="k">&lt;button</span> <span class="s">data-variant</span>=<span class="cn">"error"</span><span class="k">&gt;</span><span class="t">Error</span><span class="k">&lt;/button&gt;</span><br />
                    <span class="k">&lt;button</span> <span class="s">data-variant</span>=<span class="cn">"dark"</span><span class="k">&gt;</span><span class="t">Dark</span><span class="k">&lt;/button&gt;</span><br />
                    <span class="k">&lt;button</span> <span class="s">data-variant</span>=<span class="cn">"light"</span><span class="k">&gt;</span><span class="t">Light</span><span class="k">&lt;/button&gt;</span>
                </div>
            </div>
        </div>
    </div>

    <div class="lib-component">
        <div class="lib-component-label">Input variants</div>
        <div class="lib-preview">
            <article>
                <form>
                    <input type="text" placeholder="Default input" />
                    <input type="text" data-variant="accent" placeholder="Accent" />
                    <input type="text" data-variant="success" value="Valid value" />
                    <input type="text" data-variant="error" value="Invalid value" />
                    <input type="text" data-variant="warning" placeholder="Warning state" />
                </form>
            </article>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div class="lib-code" data-raw='<input type="text" placeholder="Default">
<input type="text" data-variant="success" value="Valid value">
<input type="text" data-variant="error" value="Invalid value">
<input type="text" data-variant="warning" placeholder="Warning state">'>
                    <span class="k">&lt;input</span> <span class="s">type</span>=<span class="cn">"text"</span> <span class="s">placeholder</span>=<span class="cn">"Default"</span><span class="k">&gt;</span><br />
                    <span class="k">&lt;input</span> <span class="s">type</span>=<span class="cn">"text"</span> <span class="s">data-variant</span>=<span class="cn">"success"</span><span class="k">&gt;</span><br />
