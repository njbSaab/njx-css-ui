<style is:global>
    /* ── Design Tokens section ── */
    .tok-group {
        display: flex;
        flex-direction: column;
        gap: 24px;
    }

    /* Colors */
    .tok-colors {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }
    .tok-swatch {
        display: flex;
        flex-direction: column;
        justify-content: flex-end;
        width: 90px;
        height: 80px;
        border-radius: 10px;
        padding: 8px;
        position: relative;
        cursor: default;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.06);
    }
    .tok-swatch-name {
        font-size: 11px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.92);
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
        line-height: 1.2;
    }
    .tok-swatch-var {
        font-size: 9.5px;
        color: rgba(255, 255, 255, 0.55);
        font-family: var(--font-mono);
        margin-top: 2px;
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.6);
    }

    .tok-scale {
        display: flex;
        border-radius: 10px;
        overflow: hidden;
        height: 44px;
        width: 100%;
    }
    .tok-scale-step {
        flex: 1;
        display: flex;
        align-items: flex-end;
        justify-content: center;
        padding-bottom: 5px;
        font-size: 9px;
        font-weight: 700;
        color: rgba(255, 255, 255, 0.7);
        text-shadow: 0 1px 3px rgba(0, 0, 0, 0.5);
        cursor: default;
    }
    .tok-scale-step.dark {
        color: rgba(0, 0, 0, 0.55);
    }

    /* Fonts */
    .tok-fonts {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }
    @media (max-width: 700px) {
        .tok-fonts {
            grid-template-columns: 1fr 1fr;
        }
    }
    .tok-font-card {
        background: var(--color-dark-secondary);
        border: 1px solid var(--color-neutral-700);
        border-radius: 10px;
        padding: 16px;
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .tok-font-sample {
        font-size: 28px;
        line-height: 1.1;
        color: var(--color-light);
        font-weight: 600;
    }
    .tok-font-meta {
        display: flex;
        flex-direction: column;
        gap: 2px;
        margin-top: 4px;
    }
    .tok-font-role {
        font-size: 10px;
        font-weight: 700;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--color-primary);
    }
    .tok-font-name {
        font-size: 11px;
        color: var(--color-muted);
        font-family: var(--font-mono);
    }

    /* Font sizes */
    .tok-sizes {
        display: flex;
        flex-direction: column;
        gap: 4px;
    }
    .tok-size-row {
        display: grid;
        grid-template-columns: 52px 1fr 60px;
        align-items: center;
        gap: 12px;
        padding: 3px 0;
    }
    .tok-size-label {
        font-size: 11px;
        color: var(--color-muted);
        font-family: var(--font-mono);
        text-align: right;
    }
    .tok-size-text {
        color: var(--color-light);
        white-space: nowrap;
        overflow: hidden;
        line-height: 1.3;
    }
    .tok-size-px {
        font-size: 10px;
        color: var(--color-neutral-500);
        font-family: var(--font-mono);
        text-align: right;
    }

    /* Spacing */
    .tok-spacing {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .tok-space-row {
        display: grid;
        grid-template-columns: 70px auto 1fr;
        align-items: center;
        gap: 12px;
    }
    .tok-space-bar {
        height: 8px;
        border-radius: 4px;
        background: color-mix(in srgb, var(--color-primary) 60%, transparent);
        flex-shrink: 0;
    }
    .tok-space-val {
        font-size: 10px;
        color: var(--color-neutral-500);
        font-family: var(--font-mono);
    }

    /* Radius */
    .tok-radii {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        align-items: flex-end;
    }
    .tok-radius-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }
    .tok-radius-box {
        background: color-mix(in srgb, var(--color-primary) 12%, transparent);
        border: 1.5px solid
            color-mix(in srgb, var(--color-primary) 40%, transparent);
        width: 52px;
        height: 52px;
    }
    .tok-radius-label {
        font-size: 10px;
        color: var(--color-muted);
        font-family: var(--font-mono);
        text-align: center;
    }

    /* Shadows */
    .tok-shadows {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
    }
    .tok-shadow-item {
        background: var(--color-dark-secondary);
        border: 1px solid var(--color-neutral-700);
        border-radius: 10px;
        padding: 16px 20px;
        display: flex;
        flex-direction: column;
        gap: 6px;
        min-width: 130px;
        align-items: center;
    }
    .tok-shadow-preview {
        width: 40px;
        height: 40px;
        border-radius: 8px;
        background: var(--color-neutral-700);
    }
    .tok-shadow-var {
        font-size: 10px;
        color: var(--color-muted);
        font-family: var(--font-mono);
    }
</style>

