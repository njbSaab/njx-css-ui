<section class="lib-section cl-section" id="headings">
    <div class="lib-section-title">𝐓 Headings &amp; Typography</div>
    <div class="lib-section-desc">
        Headings, paragraphs, blockquotes and text formatting from <code
            >_native.css</code
        >. No classes needed inside <code>&lt;article&gt;</code>.
    </div>

    <div class="lib-component">
        <div class="lib-component-label">Headings h1–h6</div>
        <div class="lib-preview">
            <article style="display: flex; flex-direction: column;">
                <h1>Heading 1 — The quick brown fox</h1>
                <h2>Heading 2 — jumps over</h2>
                <h3>Heading 3 — the lazy dog</h3>
                <h4>Heading 4 — Pack my box</h4>
                <h5>Heading 5 — with five dozen</h5>
                <h6>Heading 6 — liquor jugs</h6>
            </article>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
                    class="lib-code"
                    data-raw="<h1>Heading 1</h1>
<h2>Heading 2</h2>
<h3>Heading 3</h3>
<h4>Heading 4</h4>
<h5>Heading 5</h5>
<h6>Heading 6</h6>"
                >
                    <span class="k">&lt;h1&gt;</span><span class="t"
                        >Heading 1</span
                    ><span class="k">&lt;/h1&gt;</span><br />
                    <span class="k">&lt;h2&gt;</span><span class="t"
                        >Heading 2</span
                    ><span class="k">&lt;/h2&gt;</span><br />
                    <span class="k">&lt;h3&gt;</span><span class="t"
                        >Heading 3</span
                    ><span class="k">&lt;/h3&gt;</span><br />
                    <span class="k">&lt;h4&gt;</span><span class="t"
                        >Heading 4</span
                    ><span class="k">&lt;/h4&gt;</span><br />
                    <span class="k">&lt;h5&gt;</span><span class="t"
                        >Heading 5</span
                    ><span class="k">&lt;/h5&gt;</span><br />
                    <span class="k">&lt;h6&gt;</span><span class="t"
                        >Heading 6</span
                    ><span class="k">&lt;/h6&gt;</span>
                </div>
            </div>
        </div>
    </div>

    <div class="lib-component">
        <div class="lib-component-label">Paragraph &amp; text styles</div>
        <div class="lib-preview">
            <article>
                <p>
                    A regular paragraph with <strong>bold text</strong>, <em
                        >italic text</em
                    >, and <small>small text</small>. Mix them for <strong
                        ><em>bold italic</em></strong
                    > combinations.
                </p>
                <p>
                    Use <u>underline</u> sparingly. <s>Strikethrough</s> for outdated
                    content. <mark>Highlighted text</mark> draws attention.
                </p>
                <blockquote>
                    Design is not just what it looks like and feels like. Design
                    is how it works.
                    <cite>— Steve Jobs</cite>
                </blockquote>
            </article>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
                    class="lib-code"
                    data-raw="<p>A paragraph with <strong>bold</strong>, <em>italic</em>, <small>small</small>.</p>
<p><mark>Highlighted</mark>, <s>strikethrough</s>, <u>underline</u>.</p>
<blockquote>
  Quote text here.
  <cite>— Author</cite>
</blockquote>"
                >
                    <span class="k">&lt;p&gt;</span><span class="t"
                        >A paragraph with
                    </span><span class="k">&lt;strong&gt;</span><span class="t"
                        >bold</span
                    ><span class="k">&lt;/strong&gt;</span><span class="t"
                        >,
                    </span><span class="k">&lt;em&gt;</span><span class="t"
                        >italic</span
                    ><span class="k">&lt;/em&gt;</span><span class="t">.</span
                    ><span class="k">&lt;/p&gt;</span><br />
                    <span class="k">&lt;p&gt;&lt;mark&gt;</span><span class="t"
                        >Highlighted</span
                    ><span class="k">&lt;/mark&gt;</span><span class="t"
                        >,
                    </span><span class="k">&lt;s&gt;</span><span class="t"
                        >strikethrough</span
                    ><span class="k">&lt;/s&gt;</span><span class="k"
                        >&lt;/p&gt;</span
                    ><br />
                    <span class="k">&lt;blockquote&gt;</span><br />
                    &nbsp;&nbsp;<span class="t">Quote text here.</span><br />
                    &nbsp;&nbsp;<span class="k">&lt;cite&gt;</span><span
                        class="t">— Author</span
                    ><span class="k">&lt;/cite&gt;</span><br />
                    <span class="k">&lt;/blockquote&gt;</span>
                </div>
            </div>
        </div>
    </div>
</section>
