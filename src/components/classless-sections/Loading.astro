<section class="lib-section cl-section" id="loading">
    <div class="lib-section-title">⏳ Loading</div>
    <div class="lib-section-desc">
        <code>aria-busy="true"</code> on any block element adds a frosted overlay
        + spinning indicator from <code>_native.css</code>. Use <code
            >[role="status"]</code
        > for an inline spinner. No extra markup needed.
    </div>

    <div class="lib-component">
        <div class="lib-component-label">aria-busy on article</div>
        <div class="lib-preview">
            <article aria-busy="true" style="min-height:100px;">
                <p>Loading content…</p>
            </article>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
                    class="lib-code"
                    data-raw='<article aria-busy="true">
  <p>Loading content…</p>
</article>'
                >
                    <span class="k">&lt;article</span>
                    <span class="s">aria-busy</span>=<span class="cn"
                        >"true"</span
                    ><span class="k">&gt;</span><br />
                    &nbsp;&nbsp;<span class="k">&lt;p&gt;</span><span class="t"
                        >Loading content…</span
                    ><span class="k">&lt;/p&gt;</span><br />
                    <span class="k">&lt;/article&gt;</span>
                </div>
            </div>
        </div>
    </div>

    <div class="lib-component">
        <div class="lib-component-label">aria-busy on section</div>
        <div class="lib-preview">
            <article>
                <section
                    aria-busy="true"
                    style="min-height:90px; padding: 1.25rem; border-radius: 8px;"
                >
                    <p style="margin-top: 80px; text-align: center;">
                        Section loading…
                    </p>
                </section>
            </article>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
                    class="lib-code"
                    data-raw='<section aria-busy="true">
  <p>Section loading…</p>
</section>'
                >
                    <span class="k">&lt;section</span>
                    <span class="s">aria-busy</span>=<span class="cn"
                        >"true"</span
                    ><span class="k">&gt;</span><br />
                    &nbsp;&nbsp;<span class="k">&lt;p&gt;</span><span class="t"
                        >Section loading…</span
                    ><span class="k">&lt;/p&gt;</span><br />
                    <span class="k">&lt;/section&gt;</span>
                </div>
            </div>
        </div>
    </div>

    <div class="lib-component">
        <div class="lib-component-label">Button loading state</div>
        <div class="lib-preview">
            <article>
                <button aria-busy="true">Saving…</button>
                <button aria-busy="true" data-variant="accent"
                    >Submitting…</button
                >
                <button aria-busy="true" data-variant="success">Done</button>
            </article>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
                    class="lib-code"
                    data-raw='<button aria-busy="true">Saving…</button>
<button aria-busy="true" data-variant="accent">Submitting…</button>'
                >
                    <span class="k">&lt;button</span>
                    <span class="s">aria-busy</span>=<span class="cn"
                        >"true"</span
                    ><span class="k">&gt;</span><span class="t">Saving…</span
                    ><span class="k">&lt;/button&gt;</span><br />
                    <span class="k">&lt;button</span>
                    <span class="s">aria-busy</span>=<span class="cn"
                        >"true"</span
                    >
                    <span class="s">data-variant</span>=<span class="cn"
                        >"accent"</span
                    ><span class="k">&gt;</span><span class="t"
                        >Submitting…</span
                    ><span class="k">&lt;/button&gt;</span>
                </div>
            </div>
        </div>
    </div>

    <div class="lib-component">
        <div class="lib-component-label">
            Inline spinner — <code>data-loading</code>
        </div>
        <div class="lib-preview">
            <article>
                <p><span data-loading></span> Fetching data…</p>
                <p style="display:flex;align-items:center;gap:.5rem;">
                    <span data-loading></span>
                    <span>Syncing changes</span>
                </p>
            </article>
        </div>
        <div class="lib-code-wrapper">
            <div class="lib-code-container">
                <div
                    class="lib-code"
                    data-raw="<p><span data-loading></span> Fetching data…</p>"
                >
                    <span class="k">&lt;p&gt;</span><span class="k"
                        >&lt;span</span
                    >
                    <span class="s">data-loading</span><span class="k"
                        >&gt;&lt;/span&gt;</span
                    >
                    <span class="t">Fetching data…</span><span class="k"
                        >&lt;/p&gt;</span
                    >
                </div>
            </div>
        </div>
    </div>
</section>
