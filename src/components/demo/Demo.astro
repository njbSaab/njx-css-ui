  function writeClipboard(text) {
    if (navigator.clipboard && window.isSecureContext) {
      return navigator.clipboard.writeText(text);
    }

    const textarea = document.createElement('textarea');
    textarea.value = text;
    textarea.setAttribute('readonly', '');
    textarea.style.position = 'fixed';
    textarea.style.left = '-9999px';
    document.body.appendChild(textarea);
    textarea.select();
    document.execCommand('copy');
    textarea.remove();
    return Promise.resolve();
  }

  function initComponentExplorer(root) {
    if (root.dataset.demoCeReady === 'true') return;
    root.dataset.demoCeReady = 'true';

    let currentComponent = 'animations';
    let currentVariant = 'default';
    let currentGroup = 'popular';

    const canvas = root.querySelector('[data-ce-canvas]');
    const code = root.querySelector('[data-ce-code]');
    const search = root.querySelector('[data-ce-search]');
    const copy = root.querySelector('[data-ce-copy]');
    const items = Array.from(root.querySelectorAll('.ce-item'));
    const cats = Array.from(root.querySelectorAll('.ce-cat'));
    const tabsWrap = root.querySelector('.ce-tabs');
    const tabs = Array.from(root.querySelectorAll('.ce-tabs button'));
    const previews = Array.from(
      root.querySelectorAll('[data-section-preview]'),
    );

    function matchesGroup(el) {
      return (el.dataset.group || '').split(/\s+/).includes(currentGroup);
    }

    function itemGroups(el) {
      return (el.dataset.group || '').split(/\s+/).filter(Boolean);
    }

    function itemMatchesSearch(el, query) {
      const haystack =
        `${el.dataset.c || ''} ${el.textContent || ''}`.toLowerCase();
      return !query || haystack.includes(query);
    }

    function applyMenuFilter() {
      const query = search ? search.value.trim().toLowerCase() : '';
      const isSearching = query.length > 0;

      items.forEach((item) => {
        item.hidden = !(
          (isSearching || matchesGroup(item)) &&
          itemMatchesSearch(item, query)
        );
      });

      cats.forEach((cat) => {
        const groups = itemGroups(cat);
        cat.hidden = !items.some((item) => {
          const sharesGroup = itemGroups(item).some((group) =>
            groups.includes(group),
          );
          return sharesGroup && !item.hidden;
        });
      });
    }

    function setCurrentItem(item) {
      items.forEach((el) => el.classList.remove('on'));
      item.classList.add('on');
      currentComponent = item.dataset.c || 'button';
      render();
    }

    function render() {
      const component = CE[currentComponent] || CE.button;
      const variant = component[currentVariant] || component.default;
      const sectionPreview = previews.find(
        (preview) => preview.dataset.sectionPreview === currentComponent,
      );

      previews.forEach((preview) => {
        preview.classList.toggle('on', preview === sectionPreview);
      });

      if (canvas) {
        canvas.hidden = Boolean(sectionPreview);
        canvas.innerHTML = sectionPreview ? '' : variant.html;
      }
      if (code) {
        code.closest('.ce-code').hidden = Boolean(sectionPreview);
        code.innerHTML = variant.code;
      }
      if (tabsWrap) {
        tabsWrap.hidden = false;
      }
    }

    items.forEach((item) => {
      item.addEventListener('click', () => {
        setCurrentItem(item);
      });
    });

    tabs.forEach((tab) => {
      tab.addEventListener('click', () => {
        tabs.forEach((el) => el.classList.remove('on'));
        tab.classList.add('on');
        currentGroup = tab.dataset.v || 'popular';
        if (search) search.value = '';
        applyMenuFilter();

        const firstVisibleItem = items.find((item) => !item.hidden);
        if (firstVisibleItem) setCurrentItem(firstVisibleItem);
      });
    });

    if (search) {
      search.addEventListener('input', () => {
        applyMenuFilter();

        const activeItem = items.find((item) => item.classList.contains('on'));
        if (!activeItem || activeItem.hidden) {
          const firstVisibleItem = items.find((item) => !item.hidden);
          if (firstVisibleItem) setCurrentItem(firstVisibleItem);
        }
      });
    }

    if (copy) {
      copy.addEventListener('click', () => {
        const text = code ? code.textContent || '' : '';
        writeClipboard(text).then(() => {
          copy.textContent = 'Copied!';
          window.setTimeout(() => {
            copy.textContent = 'Copy';
          }, 1800);
        });
      });
    }

    applyMenuFilter();
    render();
  }

  function initDemoExplorers() {
    document.querySelectorAll('[data-demo-ce]').forEach(initComponentExplorer);
  }

  initDemoExplorers();
  document.addEventListener('astro:page-load', initDemoExplorers);
</script>
