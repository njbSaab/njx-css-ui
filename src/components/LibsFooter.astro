---
interface Props {
    activePage?:
        | 'njxUIComponents'
        | 'documentation'
        | 'quickstart'
        | 'overview'
        | 'donate'
        | 'contact'
        | 'classless';
}
const { activePage } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<footer class="lib-footer">
    <a class="lib-footer-logo" href={base}>njX UI</a>
    <div class="lib-footer-links">
        <a href={base} class={activePage === 'njxUIComponents' ? 'active' : ''}
            >Components</a
        >
        <a
            href={`${base}classless-components`}
            class={activePage === 'classless' ? 'active' : ''}>Classless</a
        >
        <a
            href={`${base}documentation`}
            class={activePage === 'documentation' ? 'active' : ''}
            >Documentation</a
        >
        <a
            href={`${base}quickstart`}
            class={activePage === 'quickstart' ? 'active' : ''}>Quick Start</a
        >
        <a
            href={`${base}overview`}
            class={activePage === 'overview' ? 'active' : ''}>Overview</a
        >
        <a
            href={`${base}donate`}
            class={activePage === 'donate' ? 'active' : ''}>Donate</a
        >
        <a
            href={`${base}contact`}
            class={activePage === 'contact' ? 'active' : ''}>Contact</a
        >
        <a href="https://github.com/njbSaab/njx-css-ui" target="_blank"
            >GitHub</a
        >
    </div>
    <a
        class="lib-footer-kofi"
        href="https://ko-fi.com/O5O51XAFMR"
        target="_blank"
        rel="noopener"
    >
        <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="currentColor"
        >
            <path
                d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.023c-.076-.057-.108-.09-.108-.09-.443-.441-3.368-3.049-4.034-3.954-.709-.965-1.041-2.7-.091-3.71.951-1.01 3.005-1.086 4.363.407 0 0 1.565-1.782 3.468-.963 1.904.82 1.832 3.011.723 4.311zm6.173.478c-.928.116-1.682.028-1.682.028V7.284h1.77s1.971.551 1.971 2.638c0 1.913-.985 2.667-2.059 3.015z"
            ></path>
        </svg>
        Support me on Ko-fi
    </a>
</footer>
<style is:global>
    .lib-footer-links a.active {
        color: var(--color-primary);
    }
    .lib-footer-kofi {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 16px 0 8px;
        padding: 10px 20px;
        background: linear-gradient(
            135deg,
            var(--color-primary),
            var(--color-accent)
        );
        color: #fff;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        border-radius: 8px;
        transition:
            opacity 0.2s,
            transform 0.2s;
    }
    .lib-footer-kofi:hover {
        opacity: 0.85;
        transform: translateY(-1px);
    }
</style>
