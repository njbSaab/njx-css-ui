<div
    id="njx-download-overlay"
    class="njx-dl-overlay"
    onclick="if(event.target===this)closeDownloadModal()"
>
    <div class="njx-dl-modal">

        <!-- Header -->
        <div class="njx-dl-header">
            <div class="njx-dl-header-left">
