        </div>

        <!-- ══════════════════════════════════════════════
             Panel: Quick Download (Default)
             ══════════════════════════════════════════════ -->
        <div class="njx-dl-panel" id="njx-tab-default">
            <div class="njx-dl-body njx-dl-body--default">

                <!-- Variant cards -->
