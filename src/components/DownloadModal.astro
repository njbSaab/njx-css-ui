                    <path d="M2 3h12v10H2zM2 7h12"/>
                    <path d="M5 3V1M11 3V1"/>
                </svg>
                Quick
            </button>
            <button class="njx-dl-tab" data-tab="custom" onclick="njxDlSwitchTab('custom')">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
                    <path d="M2 4h3M7 4h7M2 8h7M11 8h3M2 12h5M9 12h5"/>
                    <circle cx="5" cy="4" r="1.5"/>
                    <circle cx="9.5" cy="8" r="1.5"/>
                    <circle cx="7.5" cy="12" r="1.5"/>
                </svg>
                Custom
            </button>
            <button class="njx-dl-tab" data-tab="all" onclick="njxDlSwitchTab('all')">
                <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M1 3h14M1 8h14M1 13h14"/>
                </svg>
                All Files
