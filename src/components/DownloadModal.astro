<script is:inline>
(function () {
    var _activeTab = 'default';

    var DL_BTN_ICON = '<svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M8 1v8M5 6l3 3 3-3M2 11v1a1 1 0 001 1h10a1 1 0 001-1v-1"/></svg>';
    var DL_SPIN_ICON = '<svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5" stroke-dasharray="20" stroke-dashoffset="5"/></svg>';

    var DEF_CDN_RAW = {
        full: '<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/njx-ui/css/style.min.css">',
        classless: '<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/njx-ui/css/classless.min.css">',
        mix: '<!-- Legacy scoped mode only -->\n<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/njx-ui/css/classless-mode.css">\n<!-- add data-classless to <html> -->'
    };

    function escHtml(str) {
        return String(str)
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;');
    }

    function highlightCdnLine(line) {
        if (/^\s*<!--/.test(line)) {
            return '<span class="njx-code-comment">' + escHtml(line) + '</span>';
        }

        var out = escHtml(line);
        out = out.replace(/(&lt;\/?)([a-zA-Z-]+)/g, '$1<span class="njx-code-tag">$2</span>');
        out = out.replace(/([a-zA-Z-:]+)=(&quot;[^&]*?&quot;)/g, '<span class="njx-code-attr">$1</span>=<span class="njx-code-string">$2</span>');
        return out;
    }

    function renderCdnSnippet(variant) {
        var raw = DEF_CDN_RAW[variant] || DEF_CDN_RAW.full;
        return raw
            .split('\n')
            .map(highlightCdnLine)
            .join('\n');
    }

    // ── Tab switcher ──
    window.njxDlSwitchTab = function (tab) {
        _activeTab = tab;
        document.querySelectorAll('.njx-dl-tab').forEach(function (btn) {
            btn.classList.toggle('active', btn.dataset.tab === tab);
        });
        ['default', 'custom', 'all'].forEach(function (t) {
            var p = document.getElementById('njx-tab-' + t);
            if (p) p.classList.toggle('njx-dl-panel-hidden', t !== tab);
        });
        njxDlUpdateFooter();
    };

    // ── Variant card selector ──
    window.njxDefSelectVariant = function (variant) {
        document.querySelectorAll('.njx-vc').forEach(function(card) {
            card.classList.toggle('is-selected', card.dataset.variant === variant);
        });
        var cdnEl = document.getElementById('njx-def-cdn-code');
        if (cdnEl) {
            cdnEl.innerHTML = renderCdnSnippet(variant);
            cdnEl.dataset.copyValue = DEF_CDN_RAW[variant] || DEF_CDN_RAW.full;
        }
        njxDlUpdateFooter();
    };

    // ── Progress bar for Custom Build ──
    function njxCbUpdateProgress() {
        var panel = document.getElementById('njx-tab-custom');
        if (!panel) return;
        var all     = panel.querySelectorAll('input[type="checkbox"]');
        var checked = panel.querySelectorAll('input[type="checkbox"]:checked');
        var pct     = all.length ? (checked.length / all.length * 100) : 100;
        var bar     = document.getElementById('njx-cb-progress');
        var lbl     = document.getElementById('njx-cb-count-label');
        if (bar) bar.style.width = pct + '%';
        if (lbl) lbl.textContent = checked.length + ' of ' + all.length;

        // Section sub-counts
        var compPanel = document.getElementById('njx-dl-components');
        if (compPanel) {
            var cc = compPanel.querySelectorAll('input:checked').length;
            var ct = compPanel.querySelectorAll('input').length;
            var el = document.getElementById('njx-cb-comp-count');
            if (el) el.textContent = cc + ' / ' + ct + ' files';
        }
        var visualCbs = panel.querySelectorAll('.njx-dl-grid:last-of-type input');
        var visualChecked = panel.querySelectorAll('.njx-dl-grid:last-of-type input:checked');
        var vEl = document.getElementById('njx-cb-visual-count');
        // Simple fallback
        if (vEl) {
            var vcTotal = 3;
            var vcChecked = panel.querySelectorAll('input[value="_animations.css"]:checked, input[value="_gradients.css"]:checked, input[value="_hovers.css"]:checked').length;
            vEl.textContent = vcChecked + ' / ' + vcTotal + ' files';
        }
    }

    // ── Footer count updater ──
    function njxDlUpdateFooter() {
        var countEl = document.getElementById('njx-dl-count');
        if (!countEl) return;
        if (_activeTab === 'default') {
            var sel = document.querySelector('input[name="njx-def-variant"]:checked');
            var v = sel ? sel.value : 'full';
            var labels = { full: 'style.min.css', classless: 'classless.min.css', mix: 'style.min.css + classless-mode.css' };
            countEl.textContent = labels[v] || 'style.min.css';
        } else if (_activeTab === 'all') {
            countEl.textContent = '5 files — complete package';
        } else {
            dlUpdateCount();
        }
    }
    window.njxDlUpdateFooter = njxDlUpdateFooter;

    // ── Init variant cards (click) ──
    function initDownloadModal() {
        document.querySelectorAll('.njx-vc').forEach(function(card) {
            if (card.dataset.njxInit === '1') return;
            card.dataset.njxInit = '1';
            if (card.querySelector('input:checked')) card.classList.add('is-selected');
            card.addEventListener('click', function() {
                var radio = card.querySelector('input[type="radio"]');
                if (!radio) return;
                document.querySelectorAll('input[name="' + radio.name + '"]').forEach(function(r){ r.checked = false; });
                radio.checked = true;
                njxDefSelectVariant(card.dataset.variant);
            });
        });
        var selected = document.querySelector('input[name="njx-def-variant"]:checked');
        if (selected) njxDefSelectVariant(selected.value);
        njxCbUpdateProgress();
        njxDlUpdateFooter();
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initDownloadModal, { once: true });
    } else {
        initDownloadModal();
    }

    // ── Change events ──
    document.addEventListener('change', function (e) {
        if (e.target.name === 'njx-def-variant') {
            njxDefSelectVariant(e.target.value);
        }
        if (e.target.closest('#njx-tab-custom')) {
            njxCbUpdateProgress();
            njxDlUpdateFooter();
        }
    });

    // ── Unified download dispatcher ──
    window.njxDlDownload = function () {
        if (_activeTab === 'default') njxDownloadDefault();
        else if (_activeTab === 'all')  njxDownloadAll();
        else buildAndDownload();
    };

    // ── Default download ──
    window.njxDownloadDefault = async function () {
        var btn = document.getElementById('njx-dl-confirm');
        btn.disabled = true;
        btn.innerHTML = DL_SPIN_ICON + ' Packing...';

        var sel = document.querySelector('input[name="njx-def-variant"]:checked');
        var variant = sel ? sel.value : 'full';

        var files = {
            full:      [{ src: 'css/style.min.css',      dest: 'njx-ui/css/style.min.css' }],
            classless: [{ src: 'css/classless.min.css',  dest: 'njx-ui/css/classless.min.css' }],
            mix:       [
                { src: 'css/style.min.css',     dest: 'njx-ui/css/style.min.css' },
                { src: 'css/classless-mode.css', dest: 'njx-ui/css/classless-mode.css' }
            ]
        };

        var readmes = {
            full:      '# njX UI\nConnect: <link rel="stylesheet" href="css/style.min.css">\n<html data-theme="dark">\nMIT License\n',
            classless: '# njX Classless\nConnect: <link rel="stylesheet" href="classless.min.css">\n<html data-theme="dark">\nMIT License\n',
            mix:       '# njX Mix Mode\n<link rel="stylesheet" href="css/style.min.css">\n<link rel="stylesheet" href="css/classless-mode.css">\n<html data-classless data-theme="dark">\nMIT License\n'
        };

        var zipNames = { full: 'njx-ui-full.zip', classless: 'njx-classless.zip', mix: 'njx-mix.zip' };

        try {
            var zip = new JSZip();
            await Promise.all((files[variant] || files.full).map(async function(f) {
                var res = await fetch(f.src);
                if (res.ok) zip.file(f.dest, await res.text());
            }));
            zip.file('njx-ui/README.md', readmes[variant] || readmes.full);

            var blob = await zip.generateAsync({ type: 'blob', compression: 'DEFLATE', compressionOptions: { level: 6 } });
            var a = Object.assign(document.createElement('a'), { href: URL.createObjectURL(blob), download: zipNames[variant] || 'njx-ui.zip' });
            a.click();
            URL.revokeObjectURL(a.href);
            closeDownloadModal();
            showToast('Download ready!', 'success');
        } catch (err) {
            console.error(err);
            showToast('Download failed', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = DL_BTN_ICON + ' Download ZIP';
        }
    };

    // ── All Files download ──
    window.njxDownloadAll = async function () {
        var btn = document.getElementById('njx-dl-confirm');
        btn.disabled = true;
        btn.innerHTML = DL_SPIN_ICON + ' Packing...';

        var allFiles = [
            { src: 'css/style.min.css',      dest: 'njx-ui/css/style.min.css' },
            { src: 'css/classless.css',        dest: 'njx-ui/css/classless.css' },
            { src: 'css/classless.min.css',    dest: 'njx-ui/css/classless.min.css' },
            { src: 'css/classless-mode.css',   dest: 'njx-ui/css/classless-mode.css' },
            { src: 'js/njx.js',               dest: 'njx-ui/js/njx.js' }
        ];

        var README_ALL = '# njX UI — Complete Package\n\ncss/style.min.css     Full UI\ncss/classless.css     Classless\ncss/classless.min.css Classless minified\ncss/classless-mode.css Mix mode (html[data-classless])\njs/njx.js             JS helper\n\nMIT License\n';

        try {
            var zip = new JSZip();
            await Promise.all(allFiles.map(async function(f) {
                try { var res = await fetch(f.src); if (res.ok) zip.file(f.dest, await res.text()); } catch(e) {}
            }));
            zip.file('njx-ui/README.md', README_ALL);

            var blob = await zip.generateAsync({ type: 'blob', compression: 'DEFLATE', compressionOptions: { level: 6 } });
            var a = Object.assign(document.createElement('a'), { href: URL.createObjectURL(blob), download: 'njx-ui-complete.zip' });
            a.click();
            URL.revokeObjectURL(a.href);
            closeDownloadModal();
            showToast('Complete package downloaded!', 'success');
        } catch (err) {
            console.error(err);
            showToast('Download failed', 'error');
        } finally {
            btn.disabled = false;
            btn.innerHTML = DL_BTN_ICON + ' Download ZIP';
        }
    };

    // ── CDN copy ──
    window.njxCopyCdn = function (btn, codeId) {
        var code = document.getElementById(codeId || 'njx-def-cdn-code');
        var text = code ? (code.dataset.copyValue || code.textContent) : '';
        navigator.clipboard.writeText(text).then(function () {
            btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 15 4 10"/></svg> Copied!';
            btn.style.color = 'var(--color-primary)';
            setTimeout(function () {
                btn.innerHTML = '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg> Copy';
                btn.style.color = '';
            }, 1800);
        });
    };
})();
</script>

