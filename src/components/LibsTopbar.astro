<header class="lib-topbar">
    <a class="lib-topbar-brand" href="index.html"><span>njX UI</span></a>
    <div class="lib-topbar-sep"></div>
    <div class="lib-topbar-label">Theme</div>
    <div class="lib-theme-pills">
        <div
            class="lib-theme-pill"
            style="--pill-color:#4a4a56"
            onclick="setTheme(this,'dark')"
            title="Dark"
        >
        </div>
        <div
            class="lib-theme-pill"
            style="--pill-color:#f43f5e"
            onclick="setTheme(this,'red')"
            title="Red"
        >
        </div>
        <div
            class="lib-theme-pill"
            style="--pill-color:#3b82f6"
            onclick="setTheme(this,'blue')"
            title="Blue"
        >
        </div>
        <div
            class="lib-theme-pill"
            style="--pill-color:#22c55e"
            onclick="setTheme(this,'green')"
            title="Green"
        >
        </div>
        <div
            class="lib-theme-pill"
            style="--pill-color:#00e5ff"
            onclick="setTheme(this,'cyan')"
            title="Cyan"
        >
        </div>
        <div
            class="lib-theme-pill"
            style="--pill-color:#facc15"
            onclick="setTheme(this,'yellow')"
            title="Yellow"
        >
        </div>
        <div
            class="lib-theme-pill"
            style="--pill-color:#ec4899"
            onclick="setTheme(this,'pink')"
            title="Pink"
        >
        </div>
        <div
            class="lib-theme-pill"
            style="--pill-color:#a855f7"
            onclick="setTheme(this,'purple')"
            title="Purple"
        >
        </div>
        <div
            class="lib-theme-pill"
            style="--pill-color:#e2e8f0"
            onclick="setTheme(this,'light')"
            title="Light"
        >
        </div>
    </div>
    <!-- Search — centered absolutely -->
    <div class="lib-search" id="libSearch">
        <svg
            class="lib-search-icon"
            width="15"
            height="15"
            viewBox="0 0 16 16"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
            stroke-linecap="round"
        >
            <circle cx="6.5" cy="6.5" r="4.5"></circle>
            <path d="M10.5 10.5L14 14"></path>
        </svg>
        <input
            class="lib-search-input"
            id="libSearchInput"
            type="text"
            placeholder="Search components, utilities, tokens…"
            autocomplete="off"
            spellcheck="false"
        />
        <kbd class="lib-search-kbd">⌘K</kbd>
        <div class="lib-search-dropdown" id="libSearchDropdown"></div>
    </div>

    <div class="lib-topbar-spacer"></div>
    <button
        class="lib-download-btn"
        id="downloadBtn"
        onclick="downloadCssZip()"
        title="Download CSS"
    >
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
            <path
                d="M7 1v8M4 6l3 3 3-3M2 10v1a1 1 0 001 1h8a1 1 0 001-1v-1"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
        </svg>
        Download CSS
    </button>
    <a
        class="sc-nav-github flex items-center justify-center"
        href="https://github.com/njbSaab/njx-css-ui"
        target="_blank"
    >
        <svg width="30" height="30" viewBox="0 0 24 24" fill="currentColor">
            <path
                d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            ></path>
        </svg>
    </a>
    <div class="lib-topbar-version">v1.0.5</div>
</header>
